---
import '../styles/global.css';
import { withBase } from '../lib/site-url';
import PageFeedback from '../components/PageFeedback.astro';
import SupportModal from '../components/SupportModal.astro';
import SidebarNav from '../components/SidebarNav.astro';
import { getNavTree } from '../lib/nav';

// async + lazy → safe to build even on prerender=false pages (no init cycle).
const tree = await getNavTree();

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'Roadmap', href: withBase('roadmap') },
      { label: 'Releases', href: withBase('releases') },
      { label: 'Status', href: withBase('roadmap/status') },
    ],
  },
  {
    heading: 'Guides',
    links: [
      { label: 'User Guide', href: withBase('user-guide') },
      { label: 'Developer Guide', href: withBase('developer-guide') },
      { label: 'About', href: withBase('about') },
    ],
  },
  {
    heading: 'Explore',
    links: [
      { label: 'Tags', href: withBase('tags') },
      { label: 'RSS feed', href: withBase('rss.xml') },
    ],
  },
];
const year = new Date().getFullYear();

interface Props {
  title: string;
  description?: string;
  /** Home variant: no sidebar, no footer, no top-nav search (the hero owns it). */
  home?: boolean;
}

const { title, description = 'Help Center - planned features and release information', home = false } = Astro.props;

// Show the "was this helpful?" widget only on the about and guide pages.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const showPageFeedback = new Set(['/about', '/user-guide', '/developer-guide']).has(path);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="alternate" type="application/rss+xml" title="Help Center — Releases" href={withBase('rss.xml')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Apply the saved (or system) theme before first paint to avoid a flash.
         Kept byte-stable: its sha256 is allowlisted in the middleware CSP. -->
    <script is:inline>(function(){try{var s=localStorage.getItem('theme');var d=s?s==='dark':window.matchMedia('(prefers-color-scheme: dark)').matches;if(d)document.documentElement.classList.add('dark');}catch(e){}})();</script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-card focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-accent focus:shadow focus:ring-2 focus:ring-accent"
    >
      Skip to main content
    </a>
    <header class="sticky top-0 z-30 border-b border-border bg-card">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6" aria-label="Main navigation">
        <div class="flex items-center gap-3">
          {!home && (
            <button
              id="menu-toggle"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="app-sidebar"
              class="inline-flex items-center justify-center rounded-md border border-border bg-card p-2 text-secondary-foreground transition-colors hover:bg-muted hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-accent lg:hidden"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 6h18M3 12h18M3 18h18" />
              </svg>
            </button>
          )}
          <a href={withBase('')} class="text-lg font-semibold text-foreground hover:text-secondary-foreground">
            Help Center
          </a>
        </div>
        {!home && (
          <form role="search" method="get" action={withBase('search')} class="hidden flex-1 justify-center md:flex">
            <div class="relative w-full max-w-md">
              <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
              <input
                type="search"
                name="q"
                placeholder="Search the Help Center…"
                aria-label="Search the Help Center"
                class="w-full rounded-full border border-border bg-background py-2 pl-9 pr-4 text-sm text-foreground placeholder:text-muted-foreground focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
              />
            </div>
          </form>
        )}
        <div class="flex items-center gap-3">
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            aria-pressed="false"
            class="inline-flex items-center justify-center rounded-full border border-border bg-card p-2 text-secondary-foreground transition-colors hover:bg-muted hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
          >
            <!-- Moon: shown in light mode (click to enable dark) -->
            <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
            </svg>
            <!-- Sun: shown in dark mode (click to enable light) -->
            <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
            </svg>
          </button>
          <button
            type="button"
            aria-label="Account"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-sm font-semibold text-white transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
          >
            JD
          </button>
        </div>
      </div>
    </header>

    {home ? (
      <main id="main-content" class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6">
        <slot />
      </main>
    ) : (
      <div class="mx-auto flex w-full max-w-7xl gap-10 px-4 sm:px-6">
        <aside
          id="app-sidebar"
          class="fixed inset-y-0 left-0 z-40 w-72 -translate-x-full overflow-y-auto border-r border-border bg-card px-3 py-4 transition-transform duration-200 ease-out data-[open]:translate-x-0 lg:sticky lg:top-16 lg:z-auto lg:h-[calc(100vh-4rem)] lg:w-60 lg:shrink-0 lg:translate-x-0 lg:border-r-0 lg:bg-transparent lg:px-0 lg:py-8"
          aria-label="Sidebar navigation"
        >
          <SidebarNav tree={tree} pathname={Astro.url.pathname} />
        </aside>
        <div id="sidebar-backdrop" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden" aria-hidden="true"></div>

        <main id="main-content" class="min-w-0 flex-1 py-8">
          <slot />
          {showPageFeedback && <PageFeedback pagePath={Astro.url.pathname} />}
        </main>
      </div>
    )}

    {!home && (
    <footer class="mt-20 border-t border-border bg-card">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr]">
          <div class="sm:col-span-2 lg:col-span-1">
            <p class="text-base font-semibold text-foreground">Help Center</p>
            <p class="mt-2 max-w-xs text-sm leading-relaxed text-muted-foreground">
              Guides, releases, and platform status — everything you need to get the most out of the product.
            </p>
            <button
              type="button"
              data-open-support
              class="mt-5 inline-flex items-center gap-2 rounded-md border border-border bg-background px-3.5 py-2 text-sm font-medium text-foreground transition-colors hover:border-border-strong hover:bg-muted focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            >
              <svg class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" />
              </svg>
              Still need help?
            </button>
          </div>
          {footerColumns.map((col) => (
            <nav aria-label={col.heading}>
              <h3 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">{col.heading}</h3>
              <ul class="mt-4 space-y-3">
                {col.links.map((l) => (
                  <li>
                    <a href={l.href} class="text-sm text-secondary-foreground transition-colors hover:text-foreground">{l.label}</a>
                  </li>
                ))}
              </ul>
            </nav>
          ))}
        </div>
        <div class="mt-12 border-t border-border pt-6">
          <p class="text-xs text-muted-foreground">© {year} Help Center. Incident history retained 90 days.</p>
        </div>
      </div>
    </footer>
    )}

    <SupportModal />

    <!-- Toggle wiring. Kept is:inline + byte-stable so its sha256 is CSP-allowlisted. -->
    <script is:inline>(function(){var b=document.getElementById('theme-toggle'),r=document.documentElement;function s(){if(b)b.setAttribute('aria-pressed',r.classList.contains('dark')?'true':'false');}s();if(b)b.addEventListener('click',function(){var d=!r.classList.contains('dark');r.classList.toggle('dark',d);try{localStorage.setItem('theme',d?'dark':'light');}catch(e){}s();});})();</script>

    <!-- Mobile sidebar drawer. Kept is:inline + byte-stable so its sha256 is
         CSP-allowlisted (a bundled <script> gets inlined by Astro and blocked). -->
    <script is:inline>(function(){var btn=document.getElementById('menu-toggle'),sb=document.getElementById('app-sidebar'),bd=document.getElementById('sidebar-backdrop');function op(){if(sb)sb.setAttribute('data-open','');if(bd)bd.classList.remove('hidden');if(btn)btn.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}function cl(){if(sb)sb.removeAttribute('data-open');if(bd)bd.classList.add('hidden');if(btn)btn.setAttribute('aria-expanded','false');document.body.style.overflow='';}if(btn)btn.addEventListener('click',function(){sb&&sb.hasAttribute('data-open')?cl():op();});if(bd)bd.addEventListener('click',cl);document.addEventListener('keydown',function(e){if(e.key==='Escape')cl();});if(sb)sb.addEventListener('click',function(e){if(e.target.closest('a'))cl();});window.matchMedia('(min-width: 1024px)').addEventListener('change',function(m){if(m.matches)cl();});})();</script>
  </body>
</html>
