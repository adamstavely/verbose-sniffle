---
import '../styles/global.css';
import { withBase } from '../lib/site-url';
import PageFeedback from '../components/PageFeedback.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Product roadmap - planned features and release information' } = Astro.props;

// Show the "was this helpful?" widget only on the about and guide pages.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const showPageFeedback = new Set(['/about', '/user-guide', '/developer-guide']).has(path);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-indigo-700 focus:shadow focus:ring-2 focus:ring-indigo-500"
    >
      Skip to main content
    </a>
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6" aria-label="Main navigation">
        <a href={withBase('')} class="text-lg font-semibold text-slate-800 hover:text-slate-600">
          Product Roadmap
        </a>
        <ul class="flex flex-wrap gap-4 sm:gap-6">
          <li>
            <a href={withBase('roadmap')} class="text-slate-600 hover:text-slate-900">Roadmap</a>
          </li>
          <li>
            <a href={withBase('roadmap/status')} class="text-slate-600 hover:text-slate-900">Status</a>
          </li>
          <li>
            <a href={withBase('about')} class="text-slate-600 hover:text-slate-900">About</a>
          </li>
          <li>
            <a href={withBase('user-guide')} class="text-slate-600 hover:text-slate-900">User Guide</a>
          </li>
          <li>
            <a href={withBase('developer-guide')} class="text-slate-600 hover:text-slate-900">Developer Guide</a>
          </li>
          <li>
            <a href={withBase('releases')} class="text-slate-600 hover:text-slate-900">Releases</a>
          </li>
        </ul>
      </nav>
    </header>
    <main id="main-content" class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
      <slot />
      {showPageFeedback && <PageFeedback pagePath={Astro.url.pathname} />}
    </main>
  </body>
</html>
