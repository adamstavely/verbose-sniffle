---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureRequestCard from '../../components/FeatureRequestCard.astro';
import { db, FeatureRequest, Vote } from 'astro:db';

const requests = await db.select().from(FeatureRequest);
const votes = await db.select().from(Vote);

const voteCounts = votes.reduce(
  (acc, v) => {
    acc[v.featureRequestId] = (acc[v.featureRequestId] ?? 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const sorted = [...requests].sort(
  (a, b) => (voteCounts[b.id] ?? 0) - (voteCounts[a.id] ?? 0)
);
---

<BaseLayout title="Feature Requests - Product Roadmap" description="Vote on features you want to see">
  <h1 class="mb-6 text-2xl font-bold text-slate-900">Feature Requests</h1>
  <p class="mb-8 text-slate-600">
    Vote for features you'd like to see. The most requested items rise to the top.
  </p>
  {sorted.length === 0 ? (
    <p class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-8 text-center text-slate-600">
      No feature requests yet. <a href="/requests/new" class="font-medium text-indigo-600 hover:text-indigo-500">Submit the first one</a>.
    </p>
  ) : (
    <ul class="space-y-4" role="list">
      {sorted.map((req) => (
        <li>
          <FeatureRequestCard
            id={req.id}
            title={req.title}
            description={req.description}
            voteCount={voteCounts[req.id] ?? 0}
            status={req.status}
          />
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
