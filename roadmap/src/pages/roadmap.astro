---
export const prerender = false;

import { actions } from 'astro:actions';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import RoadmapList from '../components/RoadmapList.astro';
import FeatureRequestCard from '../components/FeatureRequestCard.astro';
import Toast from '../components/Toast.astro';
import { getCollection } from 'astro:content';
import { getVoteCounts, getVotedByMe } from '../lib/votes/elastic-votes';

const VOTER_COOKIE = 'roadmap_voter_id';
const voterId = Astro.cookies.get(VOTER_COOKIE)?.value;

const voteResult = Astro.getActionResult(actions.vote);
const voteData = voteResult?.data;
const voteSuccess = voteData?.success === true;
const voteError = voteData && 'error' in voteData ? voteData.error : undefined;
const voteMessage = voteSuccess
  ? 'Thanks for voting!'
  : voteError === 'already_voted'
    ? "You've already voted."
    : voteError ?? null;

const roadmapItems = await getCollection('roadmap');
const requests = await getCollection('featureRequests');
const [voteCounts, votedByMe] = await Promise.all([
  getVoteCounts(),
  getVotedByMe(voterId ?? ''),
]);

const sortedRequests = [...requests].sort(
  (a, b) => (voteCounts[b.data.id] ?? 0) - (voteCounts[a.data.id] ?? 0)
);
---

<BaseLayout title="Roadmap - Help Center" description="What's coming soon - planned features and community votes">
  {voteMessage && (
    <Toast
      message={voteMessage}
      variant={voteSuccess || voteError === 'already_voted' ? 'success' : 'error'}
    />
  )}
  <PageHeader title="Roadmap">
    See what we're planning, vote on features you want, and request new ones.
  </PageHeader>

  <section class="mb-12">
    <h2 class="mb-4 text-lg font-semibold text-secondary-foreground">Planned & In Progress</h2>
    <RoadmapList items={roadmapItems} />
  </section>

  <section>
    <h2 class="mb-4 text-lg font-semibold text-secondary-foreground">Feature Requests</h2>
    <p class="mb-4 text-sm text-secondary-foreground">
      Vote for features you'd like to see. The most requested items rise to the top.
    </p>
    {sortedRequests.length === 0 ? (
      <p class="rounded-lg border border-dashed border-border-strong bg-muted p-8 text-center text-secondary-foreground">
        No feature requests yet.
      </p>
    ) : (
      <ul class="space-y-4" role="list">
        {sortedRequests.map((req) => (
          <li>
            <FeatureRequestCard
              id={req.data.id}
              title={req.data.title}
              description={req.data.description}
              voteCount={voteCounts[req.data.id] ?? 0}
              status={req.data.status}
              hasVoted={votedByMe.has(req.data.id)}
            />
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
