---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocList from '../components/DocList.astro';
import PageHeader from '../components/PageHeader.astro';
import RoleGuides from '../components/RoleGuides.astro';
import UserGuideIntro from '../components/UserGuideIntro.astro';
import { getNavTree } from '../lib/nav';

const ug = (await getNavTree()).items.find(
  (i) => i.kind === 'group' && i.slug === 'user-guide'
);
const categories = ug && ug.kind === 'group' ? ug.categories ?? [] : [];
---

<BaseLayout title="User Guide - Help Center" description="How to use the product, organized the Diátaxis way.">
  <PageHeader title="User Guide">
    <div class="intro"><UserGuideIntro /></div>
  </PageHeader>

  <RoleGuides />

  <div class="mb-6 border-t border-border pt-8">
    <h2 class="text-lg font-semibold text-foreground">Or browse everything</h2>
    <p class="mt-1 text-sm text-secondary-foreground">
      All guides, organized with <a href="https://diataxis.fr/" class="text-accent hover:text-accent-hover">Diátaxis</a> —
      learning, tasks, lookup, and understanding.
    </p>
  </div>

  <div class="space-y-10">
    {categories.map((c) => (
      <section id={c.slug} aria-labelledby={`h-${c.slug}`} class="scroll-mt-20">
        <h2 id={`h-${c.slug}`} class="mb-1 text-lg font-semibold text-foreground">{c.name}</h2>
        <p class="mb-4 text-sm text-muted-foreground">{c.description}</p>
        <DocList pages={c.pages} emptyText={`No ${c.name.toLowerCase()} yet.`} />
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .intro :global(a) {
    color: var(--color-accent);
  }
  .intro :global(a:hover) {
    color: var(--color-accent-hover);
  }
</style>
