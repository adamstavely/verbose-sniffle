---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocList from '../components/DocList.astro';
import PageHeader from '../components/PageHeader.astro';
import UserGuideIllustration from '../components/illustrations/UserGuideIllustration.astro';
import { getNavTree } from '../lib/nav';

const ug = (await getNavTree()).items.find(
  (i) => i.kind === 'group' && i.slug === 'user-guide'
);
const categories = ug && ug.kind === 'group' ? ug.categories ?? [] : [];
const tutorialsHref = categories.find((c) => c.slug === 'tutorials')?.href;
---

<BaseLayout title="User Guide - Help Center" description="How to use the product, organized the Diátaxis way.">
  <PageHeader title="User Guide">
    <UserGuideIllustration slot="icon" />
    Browse the guides, organized with <a href="https://diataxis.fr/" class="link">Diátaxis</a> —
    learning, tasks, and lookup. New here? Start with the
    <a href={tutorialsHref} class="link">Tutorials</a>.
  </PageHeader>

  <div class="space-y-10">
    {categories.map((c) => (
      <section id={c.slug} aria-labelledby={`h-${c.slug}`} class="scroll-mt-20">
        <h2 id={`h-${c.slug}`} class="mb-1 text-lg font-semibold text-foreground">{c.name}</h2>
        <p class="mb-4 text-sm text-muted-foreground">{c.description}</p>
        <DocList pages={c.pages} layout="grid" emptyText={`No ${c.name.toLowerCase()} yet.`} />
      </section>
    ))}
  </div>
</BaseLayout>
