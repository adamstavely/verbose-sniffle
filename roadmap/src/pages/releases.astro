---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ReleasesIllustration from '../components/illustrations/ReleasesIllustration.astro';
import TagList from '../components/TagList.astro';
import { withBase } from '../lib/site-url';

const entries = (await getCollection('releases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const rendered = await Promise.all(
  entries.map(async (e) => ({ entry: e, Content: (await render(e)).Content }))
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Releases - Help Center" description="Release notes and version history.">
  <PageHeader title="Release Notes">
    <ReleasesIllustration slot="icon" />
    <a
      slot="actions"
      href={withBase('rss.xml')}
      class="inline-flex items-center gap-1.5 text-sm text-accent-hover hover:text-accent"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9" />
        <path d="M4 4a16 16 0 0 1 16 16" />
        <circle cx="5" cy="19" r="1" />
      </svg>
      RSS
    </a>
    Version history, release notes, and what's new.
  </PageHeader>

  {rendered.length === 0 ? (
    <p class="rounded-lg border border-dashed border-border-strong bg-muted p-6 text-secondary-foreground">
      No releases yet.
    </p>
  ) : (
    <div class="space-y-10">
      {rendered.map(({ entry, Content }) => (
        <article id={entry.id} class="scroll-mt-8 border-l-2 border-border pl-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="rounded bg-accent-subtle px-2 py-0.5 font-mono text-xs font-semibold text-accent-hover">
              v{entry.data.version}
            </span>
            <time datetime={entry.data.date.toISOString()} class="text-xs text-muted-foreground">
              {fmtDate(entry.data.date)}
            </time>
          </div>
          <h2 class="mt-2 text-lg font-semibold text-foreground">{entry.data.title}</h2>
          <p class="mt-1 text-secondary-foreground">{entry.data.summary}</p>
          {entry.data.tags && entry.data.tags.length > 0 && (
            <TagList tags={entry.data.tags} linked={false} class="mt-3" />
          )}
          <div class="release-notes mt-4">
            <Content />
          </div>
        </article>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  /* Scoped prose for rendered release notes (this page doesn't use MdxDocLayout). */
  .release-notes :global(h2) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 1.25rem 0 0.4rem;
  }
  .release-notes :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .release-notes :global(li) {
    margin-bottom: 0.25rem;
    color: var(--color-secondary-foreground);
    line-height: 1.6;
  }
  .release-notes :global(p) {
    margin-bottom: 0.5rem;
    color: var(--color-secondary-foreground);
    line-height: 1.6;
  }
  .release-notes :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }
  .release-notes :global(code) {
    background: var(--color-muted);
    color: var(--color-foreground);
    border-radius: 0.25rem;
    padding: 0.05rem 0.3rem;
    font-size: 0.85em;
  }
  .release-notes :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .release-notes :global(a:hover) {
    color: var(--color-accent-hover);
  }
</style>
