---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../../components/status/StatusBadge.astro';
import { entryToIncidentSummary } from '../../../../lib/status/status-content';
import { withBase } from '../../../../lib/site-url';

export async function getStaticPaths() {
  const entries = await getCollection('statusActiveIncidents');
  return entries.map((e) => ({ params: { id: e.data.id } }));
}

const { id } = Astro.params;
const entries = await getCollection('statusActiveIncidents');
const entry = entries.find((e) => e.data.id === id);
if (!entry) throw new Error(`Unknown incident: ${id}`);

const incident = entryToIncidentSummary(entry);
const { Content } = await render(entry);
---

<BaseLayout
  title={`${incident.title} - Status`}
  description={incident.description ?? incident.title}
>
  <div class="max-w-4xl mx-auto">
    <a href={withBase('roadmap/status')} class="text-sm text-indigo-600 hover:text-indigo-700 mb-4 inline-block">
      ← Back to Status
    </a>
    <div class="flex items-center justify-between gap-4 mt-2">
      <h1 class="text-2xl font-semibold text-slate-900">{incident.title}</h1>
      <StatusBadge level={incident.level} variant="pillCompact" />
    </div>

    {incident.description && (
      <p class="mt-4 text-slate-600">{incident.description}</p>
    )}

    {incident.aiNote && (
      <p class="mt-4 rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2 text-sm text-indigo-900">
        <strong class="font-semibold">Note:</strong> {incident.aiNote}
      </p>
    )}

    {incident.workaround && (
      <div class="mt-4 rounded-lg bg-amber-50 border border-amber-200 p-4">
        <h2 class="text-sm font-semibold text-amber-800">Workaround</h2>
        <p class="mt-1 text-sm text-amber-700">{incident.workaround}</p>
      </div>
    )}

    {incident.updates && incident.updates.length > 0 && (
      <section class="mt-8" aria-labelledby="updates-heading">
        <h2 id="updates-heading" class="text-lg font-semibold text-slate-900 mb-4">
          Updates
        </h2>
        <ul class="space-y-3">
          {incident.updates
            .sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime())
            .map((u) => (
              <li class="rounded-lg border border-slate-200 bg-white p-4">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-slate-500">
                    {new Date(u.timestamp).toLocaleString()}
                  </span>
                  {u.status && (
                    <span class="font-medium text-slate-700">{u.status}</span>
                  )}
                </div>
                <p class="mt-1 text-slate-700">{u.message}</p>
              </li>
            ))}
        </ul>
      </section>
    )}

    {entry.body?.trim() && (
      <div class="mt-8 text-slate-700 [&_p]:mt-3 [&_p:first-child]:mt-0">
        <Content />
      </div>
    )}

    <p class="mt-6 text-sm text-slate-500">
      Started {new Date(incident.startedAt).toLocaleString()}
      {incident.resolvedAt && ` · Resolved ${new Date(incident.resolvedAt).toLocaleString()}`}
    </p>
  </div>
</BaseLayout>
