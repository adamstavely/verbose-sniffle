---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../../components/status/StatusBadge.astro';
import { entryToIncidentSummary } from '../../../../lib/status/status-content';
import { getUpdateStatusDotClass } from '../../../../lib/status/status-utils';
import { withBase } from '../../../../lib/site-url';

export async function getStaticPaths() {
  const entries = await getCollection('statusActiveIncidents');
  return entries.map((e) => ({ params: { id: e.data.id } }));
}

const { id } = Astro.params;
const entries = await getCollection('statusActiveIncidents');
const entry = entries.find((e) => e.data.id === id);
if (!entry) throw new Error(`Unknown incident: ${id}`);

const incident = entryToIncidentSummary(entry);
const { Content } = await render(entry);

// Newest update first — the incident timeline reads top-down as it unfolds.
const sortedUpdates = (incident.updates ?? [])
  .slice()
  .sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
const latestUpdateTs = sortedUpdates[0]?.timestamp;

const timestampFmt: Intl.DateTimeFormatOptions = {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
};

/** How long before the latest update this one landed (e.g. "1 hour earlier"). */
function relativeEarlier(ts: string): string | null {
  if (!latestUpdateTs) return null;
  const ms = new Date(latestUpdateTs).getTime() - new Date(ts).getTime();
  if (ms < 60_000) return null;
  const mins = Math.round(ms / 60_000);
  if (mins < 60) return `${mins} min earlier`;
  const hours = Math.round(mins / 60);
  if (hours < 24) return `${hours} hour${hours === 1 ? '' : 's'} earlier`;
  const days = Math.round(hours / 24);
  return `${days} day${days === 1 ? '' : 's'} earlier`;
}
---

<BaseLayout
  title={`${incident.title} - Status`}
  description={incident.description ?? incident.title}
>
  <div>
    <a href={withBase('roadmap/status')} class="link text-sm mb-4 inline-block">
      ← Back to Status
    </a>
    <div class="flex items-center justify-between gap-4 mt-2">
      <h1 class="text-2xl font-semibold text-foreground">{incident.title}</h1>
      <StatusBadge level={incident.level} variant="pillCompact" />
    </div>

    {incident.description && (
      <p class="mt-4 text-secondary-foreground">{incident.description}</p>
    )}

    {incident.aiNote && (
      <p class="mt-4 rounded-lg border border-accent bg-accent-subtle px-3 py-2 text-sm text-accent-hover">
        <strong class="font-semibold">Note:</strong> {incident.aiNote}
      </p>
    )}

    {incident.workaround && (
      <div class="mt-4 rounded-lg bg-warning-subtle border border-warning/40 p-4">
        <h2 class="text-sm font-semibold text-warning-strong">Workaround</h2>
        <p class="mt-1 text-sm text-warning-strong">{incident.workaround}</p>
      </div>
    )}

    {sortedUpdates.length > 0 && (
      <section class="mt-8" aria-labelledby="updates-heading">
        <div class="overflow-hidden rounded-xl border border-border bg-card">
          <div class="border-b border-border px-5 py-4">
            <h2 id="updates-heading" class="text-lg font-semibold text-foreground">Updates</h2>
          </div>
          <ol class="px-5 py-5">
            {sortedUpdates.map((u, i) => {
              const rel = relativeEarlier(u.timestamp);
              const isLast = i === sortedUpdates.length - 1;
              return (
                <li class="relative flex gap-4 pb-6 last:pb-0">
                  {!isLast && (
                    <span class={`absolute bottom-0 left-[5px] top-5 w-px ${getUpdateStatusDotClass(u.status)}`} aria-hidden="true" />
                  )}
                  <span class={`relative z-10 mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full ${getUpdateStatusDotClass(u.status)}`} aria-hidden="true" />
                  <div class="min-w-0 flex-1">
                    {u.status && <div class="font-semibold text-foreground">{u.status}</div>}
                    <p class="mt-1 text-secondary-foreground">{u.message}</p>
                    <p class="mt-2 text-sm text-muted-foreground">
                      {new Date(u.timestamp).toLocaleString(undefined, timestampFmt)}
                      {rel && <span class="text-muted-foreground/70"> ({rel})</span>}
                    </p>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      </section>
    )}

    {entry.body?.trim() && (
      <div class="mt-8 text-secondary-foreground [&_p]:mt-3 [&_p:first-child]:mt-0">
        <Content />
      </div>
    )}

    <p class="mt-6 text-sm text-muted-foreground">
      Started {new Date(incident.startedAt).toLocaleString()}
      {incident.resolvedAt && ` · Resolved ${new Date(incident.resolvedAt).toLocaleString()}`}
    </p>
  </div>
</BaseLayout>
