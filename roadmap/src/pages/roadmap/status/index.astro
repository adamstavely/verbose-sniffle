---
export const prerender = false;

import { actions } from 'astro:actions';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import StatusBadge from '../../../components/status/StatusBadge.astro';
import Capabilities from '../../../components/status/Capabilities.astro';
import UptimeBar from '../../../components/status/UptimeBar.astro';
import SubscribeNotifications from '../../../components/status/SubscribeNotifications.astro';
import {
  getActiveIncidentsFromContent,
  getMaintenanceFromContent,
  getRecentIncidentsFromContent,
} from '../../../lib/status/status-content';
import { buildCapabilityGroups } from '../../../lib/status/capability-groups';
import { fetchSummary, fetchUptime, fetchExternalSystems } from '../../../lib/status/fetch-status';
import { getExternalSystemTypeLabel } from '../../../lib/status/status-labels';
import { withBase } from '../../../lib/site-url';

const subscribeResult = Astro.getActionResult(actions.subscribe);

// Incident/maintenance/recent sections are Markdown-driven; the live telemetry
// (summary, capabilities, uptime, external systems) comes from Elasticsearch via
// fetch-status. In production an ES failure surfaces as an honest unknown/empty
// state; mock data is only used in the explicit PUBLIC_USE_MOCK_STATUS demo mode.
const [incidents, maintenanceList, recentIncidents, summaryDto, uptime, externalDto] =
  await Promise.all([
    getActiveIncidentsFromContent(),
    getMaintenanceFromContent(),
    getRecentIncidentsFromContent(),
    fetchSummary(),
    fetchUptime(),
    fetchExternalSystems(),
  ]);

const { summary, coreServices } = summaryDto;
const capabilityGroups = buildCapabilityGroups(coreServices);
const externalSystems = externalDto.systems;
const activeMaintenance = maintenanceList.filter((m) => m.status !== 'COMPLETED');
const recent = recentIncidents.slice(0, 10);
---

<BaseLayout
  title="Status - Help Center"
  description="Platform status: live service health, active issues, scheduled maintenance, and recent incidents."
>
  <div class="max-w-4xl mx-auto space-y-12">
    <PageHeader title="Platform status">
      <StatusBadge slot="actions" level={summary.level} variant="pillCompact" />
      {summary.overallMessage}
      <p slot="meta" class="mt-1 text-xs text-muted-foreground">
        {summary.environment} · updated {new Date(summary.lastUpdated).toLocaleString()}
      </p>
    </PageHeader>

    <section aria-labelledby="capabilities-heading">
      <h2 id="capabilities-heading" class="text-lg font-semibold text-foreground mb-3">Service health</h2>
      <Capabilities groups={capabilityGroups} />
    </section>

    <section aria-labelledby="uptime-heading">
      <h2 id="uptime-heading" class="text-lg font-semibold text-foreground mb-3">90-day uptime</h2>
      {uptime.days.length > 0 ? (
        <UptimeBar data={uptime} />
      ) : (
        <p class="rounded-lg border border-border bg-card p-5 text-sm text-muted-foreground">
          Uptime data is currently unavailable.
        </p>
      )}
    </section>

    <section aria-labelledby="incidents-heading">
      <h2 id="incidents-heading" class="text-lg font-semibold text-foreground mb-3">Known Issues</h2>
      {incidents.length > 0 ? (
        <>
          <p class="text-sm text-secondary-foreground mb-4">
            Active incidents we're investigating. Workarounds and updates appear below.
          </p>
          <ul class="space-y-4">
            {incidents.map((inc) => (
              <li class="rounded-lg border border-border bg-card p-4 shadow-sm">
                <div class="flex items-center justify-between gap-4">
                  <a
                    href={withBase(`roadmap/status/incidents/${inc.id}`)}
                    class="font-medium text-foreground hover:text-accent"
                  >
                    {inc.title}
                  </a>
                  <StatusBadge level={inc.level} variant="pillCompact" />
                </div>
                {inc.description && (
                  <p class="mt-2 text-sm text-secondary-foreground">{inc.description}</p>
                )}
                {inc.workaround && (
                  <p class="mt-2 text-sm text-warning-strong bg-warning-subtle rounded p-2">
                    <strong>Workaround:</strong> {inc.workaround}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </>
      ) : (
        <p class="text-sm text-secondary-foreground">No active incidents.</p>
      )}
    </section>

    {activeMaintenance.length > 0 && (
      <section aria-labelledby="maintenance-heading">
        <h2 id="maintenance-heading" class="text-lg font-semibold text-foreground mb-3">
          Scheduled maintenance
        </h2>
        <ul class="space-y-3">
          {activeMaintenance.map((m) => (
            <li class="rounded-lg border border-border bg-info-subtle p-4">
              <div class="font-medium text-foreground">{m.title}</div>
              {m.description && (
                <p class="mt-1 text-sm text-secondary-foreground">{m.description}</p>
              )}
              <p class="mt-2 text-xs text-muted-foreground">
                {new Date(m.scheduledStart).toLocaleString()} – {new Date(m.scheduledEnd).toLocaleString()}
              </p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section aria-labelledby="external-heading">
      <div class="flex items-center justify-between mb-3">
        <h2 id="external-heading" class="text-lg font-semibold text-foreground">Connected services</h2>
        <a href={withBase('roadmap/status/external-systems')} class="text-sm text-accent hover:text-accent-hover">
          View all →
        </a>
      </div>
      <ul class="space-y-2">
        {externalSystems.map((sys) => (
          <li class="flex items-center justify-between rounded border border-border bg-card px-4 py-2 text-sm">
            <div>
              <span class="font-medium text-foreground">{sys.name}</span>
              <span class="ml-2 text-muted-foreground">{getExternalSystemTypeLabel(sys.type)}</span>
            </div>
            <StatusBadge level={sys.level} variant="pillCompact" />
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="recent-heading">
      <h2 id="recent-heading" class="text-lg font-semibold text-foreground mb-3">Recent incidents</h2>
      <p class="text-sm text-secondary-foreground mb-4">Resolved incidents from the last 90 days.</p>
      <ul class="space-y-2">
        {recent.map((inc) => (
          <li class="flex items-center justify-between rounded border border-border bg-card px-4 py-2 text-sm">
            <div>
              <span class="text-muted-foreground">{inc.date}</span>
              <span class="ml-2 font-medium text-foreground">{inc.title}</span>
            </div>
            <StatusBadge level={inc.severity} variant="pillCompact" />
          </li>
        ))}
      </ul>
    </section>

    <section id="status-subscribe" aria-labelledby="subscribe-heading">
      <h2 id="subscribe-heading" class="text-lg font-semibold text-foreground mb-3">Get incident notifications</h2>
      <p class="text-sm text-secondary-foreground mb-4">Enter your email to receive incident and maintenance notifications.</p>
      <SubscribeNotifications result={subscribeResult?.data} />
    </section>
  </div>

  <footer class="max-w-4xl mx-auto pt-8 mt-12 border-t border-border text-sm text-muted-foreground">
    <p>Questions? Contact the Platform team via the #platform-support channel.</p>
    <p class="mt-1">Incident history retained 90 days.</p>
  </footer>
</BaseLayout>
