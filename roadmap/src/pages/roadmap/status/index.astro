---
export const prerender = false;

import { actions } from 'astro:actions';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusSkeleton from '../../../components/status/StatusSkeleton.astro';
import SubscribeNotifications from '../../../components/status/SubscribeNotifications.astro';

const subscribeResult = Astro.getActionResult(actions.subscribe);
---
<BaseLayout
  title="Status - Product Roadmap"
  description="Real-time status of the Super App platform. See what's working and what we're fixing."
>
  <div id="status-root">
    <StatusSkeleton />
  </div>

  <section id="status-subscribe" aria-labelledby="subscribe-heading" class="max-w-4xl mx-auto mt-12">
    <h2 id="subscribe-heading" class="text-lg font-semibold text-slate-900 mb-3">Get incident notifications</h2>
    <p class="text-sm text-slate-600 mb-4">Enter your email to receive incident notifications.</p>
    <SubscribeNotifications result={subscribeResult?.data} />
  </section>

  <footer class="max-w-4xl mx-auto pt-8 mt-12 border-t border-slate-200 text-sm text-slate-500">
    <p>Questions? Contact the Platform team via the #platform-support channel.</p>
    <p class="mt-1">Incident history retained 90 days.</p>
  </footer>

  <script>
    (async function () {
      const root = document.getElementById('status-root');
      if (!root) return;

      try {
        const res = await fetch('/api/page-status-data');
        if (!res.ok) throw new Error('Failed to load status');
        const html = await res.text();
        root.innerHTML = html;
      } catch (err) {
        root.innerHTML = `
          <div class="max-w-4xl mx-auto rounded-xl border border-amber-200 bg-amber-50 p-6 text-amber-800">
            <p class="font-medium">Unable to load status</p>
            <p class="mt-1 text-sm">Please refresh the page or try again later.</p>
          </div>
        `;
      } finally {
        root.setAttribute('aria-busy', 'false');
      }
    })();
  </script>
</BaseLayout>
