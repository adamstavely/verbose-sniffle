---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { renderStatusContent } from '../../../lib/status/render-status-html';
import {
  getActiveIncidentsFromContent,
  getMaintenanceFromContent,
  getRecentIncidentsFromContent,
} from '../../../lib/status/status-content';
import { withBase } from '../../../lib/site-url';

const [incidents, maintenanceList, recentIncidents] = await Promise.all([
  getActiveIncidentsFromContent(),
  getMaintenanceFromContent(),
  getRecentIncidentsFromContent(),
]);

const statusHtml = renderStatusContent({
  incidents,
  maintenance: maintenanceList,
  recentIncidents,
  incidentDetailPath: (id) => withBase(`roadmap/status/incidents/${id}`),
});
---

<BaseLayout
  title="Status - Product Roadmap"
  description="Platform status: active issues, scheduled maintenance, and recent incidents (edit Markdown under src/content/status/)."
>
  <div id="status-root" set:html={statusHtml} />

  <footer class="max-w-4xl mx-auto pt-8 mt-12 border-t border-slate-200 text-sm text-slate-500">
    <p>Questions? Contact the Platform team via the #platform-support channel.</p>
    <p class="mt-1">Incident history retained 90 days.</p>
  </footer>
</BaseLayout>
