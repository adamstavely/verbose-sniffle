---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageMetaFooter from '../../../components/PageMetaFooter.astro';
import StatusBanner from '../../../components/status/StatusBanner.astro';
import StatusCard from '../../../components/status/StatusCard.astro';
import StatusLegend from '../../../components/status/StatusLegend.astro';
import { getActiveIncidentsFromContent, getMaintenanceFromContent } from '../../../lib/status/status-content';
import { fetchSummary, fetchServiceUptime } from '../../../lib/status/fetch-status';
import {
  getConnectedSystems,
  getConnectedSystemUptime,
} from '../../../lib/status/connected-services';
import { getExternalSystemTypeLabel } from '../../../lib/status/status-labels';
import { withBase } from '../../../lib/site-url';

// Data sources on this page:
//   • Status banner + System status (service health + per-service 90-day uptime)
//     → live Elasticsearch telemetry (fetch-status). In production an ES failure
//     surfaces as an honest unknown/empty state; mock data is only used in the
//     explicit PUBLIC_USE_MOCK_STATUS demo mode.
//   • Active incidents + Scheduled maintenance → Markdown (src/content/status/**).
//   • Connected services → the curated list in lib/status/connected-services.ts.
const [incidents, maintenanceList, summaryDto, serviceUptime] = await Promise.all([
  getActiveIncidentsFromContent(),
  getMaintenanceFromContent(),
  fetchSummary(),
  fetchServiceUptime(),
]);

const { summary, coreServices } = summaryDto;
const activeMaintenance = maintenanceList.filter((m) => m.status !== 'COMPLETED');

const serviceRows = coreServices.map((s) => ({
  name: s.name,
  level: s.level,
  uptime: serviceUptime[s.id],
  info: s.impact,
}));

const connectedUptime = getConnectedSystemUptime();
const connectedRows = getConnectedSystems().map((sys) => ({
  name: sys.name,
  level: sys.level,
  meta: getExternalSystemTypeLabel(sys.type),
  uptime: connectedUptime[sys.id],
}));

const monthYear = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const rangeLabel = `${monthYear(new Date(Date.now() - 90 * 24 * 60 * 60 * 1000))} – ${monthYear(new Date())}`;
---

<BaseLayout
  title="Status - Help Center"
  description="Platform status: live service health, active issues, scheduled maintenance, and incident history."
>
  <h1 class="sr-only">System status</h1>
  <div class="space-y-8">
    <StatusBanner level={summary.level} incidents={incidents} maintenance={activeMaintenance} />

    <StatusCard title="System status" rangeLabel={rangeLabel} rows={serviceRows} />

    <StatusLegend />

    <StatusCard
      title="Connected services"
      rangeLabel={rangeLabel}
      rows={connectedRows}
      link={{ href: withBase('roadmap/status/external-systems'), label: 'View all →' }}
    />

    <div class="flex justify-center">
      <a
        href={withBase('roadmap/status/history')}
        class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted"
      >
        View incident history →
      </a>
    </div>
  </div>

  <PageMetaFooter lastUpdated={summary.lastUpdated} />
</BaseLayout>
