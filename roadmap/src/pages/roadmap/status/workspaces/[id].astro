---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../../components/status/StatusBadge.astro';
import { fetchWorkspaceFeatures, fetchExternalSystems, fetchWorkspaces } from '../../../../lib/status/fetch-status';
import { getFeatureDisplayName } from 'shared/status-labels';

const { id } = Astro.params;
if (!id) return Astro.redirect('/roadmap/status');

const [featuresRes, externalRes, workspacesRes] = await Promise.all([
  fetchWorkspaceFeatures(id),
  fetchExternalSystems(),
  fetchWorkspaces(),
]);

const features = featuresRes.features;
const externalSystems = externalRes.systems;
const workspace = workspacesRes.workspaces.find((w) => w.id === id);
const workspaceName = workspace?.name ?? `Workspace ${id}`;
---

<BaseLayout
  title={`${workspaceName} - Status`}
  description={`Feature status for ${workspaceName}`}
>
  <div class="max-w-4xl mx-auto">
    <a href="/roadmap/status" class="text-sm text-indigo-600 hover:text-indigo-700 mb-4 inline-block">
      ← Back to Status
    </a>
    <h1 class="text-2xl font-semibold text-slate-900 mt-2">{workspaceName}</h1>

    <section class="mt-8" aria-labelledby="features-heading">
      <h2 id="features-heading" class="text-lg font-semibold text-slate-900 mb-4">
        Feature status
      </h2>
      <div class="overflow-x-auto rounded-lg border border-slate-200">
        <table class="min-w-full divide-y divide-slate-200">
          <thead className="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Feature</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Status</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Last seen</th>
            </tr>
          </thead>
          <tbody className="divide-y divide-slate-200 bg-white">
            {features.map((f) => (
              <tr>
                <td class="px-4 py-3 text-sm text-slate-900">
                  {getFeatureDisplayName(f.featureId)}
                </td>
                <td class="px-4 py-3">
                  <StatusBadge level={f.level} variant="pillCompact" />
                </td>
                <td class="px-4 py-3 text-sm text-slate-500">
                  {new Date(f.lastSeen).toLocaleString()}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8" aria-labelledby="external-heading">
      <h2 id="external-heading" class="text-lg font-semibold text-slate-900 mb-4">
        Connected services
      </h2>
      <ul class="space-y-2">
        {externalSystems.map((sys) => (
          <li class="flex items-center justify-between rounded border border-slate-200 bg-white px-4 py-2">
            <span class="text-sm text-slate-900">{sys.name}</span>
            <StatusBadge level={sys.level} variant="pillCompact" />
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
