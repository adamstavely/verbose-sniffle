---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../../components/status/StatusBadge.astro';
import { getFeatureDisplayName } from 'shared/status-labels';
import {
  fetchWorkspaceFeatures,
  fetchExternalSystems,
  fetchWorkspaces,
} from '../../../../lib/status/fetch-status';
import { withBase } from '../../../../lib/site-url';

const { id } = Astro.params;
if (!id) return Astro.redirect(withBase('roadmap/status'));

const [featuresRes, externalRes, workspacesRes] = await Promise.all([
  fetchWorkspaceFeatures(id),
  fetchExternalSystems(),
  fetchWorkspaces(),
]);

const features = featuresRes.features;
const externalSystems = externalRes.systems;
const workspace = workspacesRes.workspaces.find((w) => w.id === id);
const workspaceName = workspace?.name ?? `Workspace ${id}`;
---

<BaseLayout
  title={`${workspaceName} - Status`}
  description={`Feature status for ${workspaceName}`}
>
  <div class="max-w-4xl mx-auto">
    <a href={withBase('roadmap/status')} class="link text-sm mb-4 inline-block">
      ← Back to Status
    </a>
    <h1 class="text-2xl font-semibold text-foreground mt-2">{workspaceName}</h1>

    <section class="mt-8" aria-labelledby="features-heading">
      <h2 id="features-heading" class="text-lg font-semibold text-foreground mb-4">
        Feature status
      </h2>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted">
            <tr>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Feature</th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Status</th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Last seen</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border bg-card">
            {features.map((f) => (
              <tr>
                <td class="px-4 py-3 text-sm text-foreground">
                  {getFeatureDisplayName(f.featureId)}
                </td>
                <td class="px-4 py-3">
                  <StatusBadge level={f.level} variant="pillCompact" />
                </td>
                <td class="px-4 py-3 text-sm text-muted-foreground">
                  {new Date(f.lastSeen).toLocaleString()}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8" aria-labelledby="external-heading">
      <h2 id="external-heading" class="text-lg font-semibold text-foreground mb-4">
        Connected services
      </h2>
      <ul class="space-y-2">
        {externalSystems.map((sys) => (
          <li class="flex items-center justify-between rounded border border-border bg-card px-4 py-2">
            <span class="text-sm text-foreground">{sys.name}</span>
            <StatusBadge level={sys.level} variant="pillCompact" />
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
