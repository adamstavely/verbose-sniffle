---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../components/status/StatusBadge.astro';
import { fetchExternalSystems } from '../../../lib/status/fetch-status';
import { getExternalSystemTypeLabel } from 'shared/status-labels';

const { systems } = await fetchExternalSystems();
---

<BaseLayout
  title="Connected Services - Status"
  description="External systems and dependencies status"
>
  <div class="max-w-4xl mx-auto">
    <a href="/roadmap/status" class="text-sm text-indigo-600 hover:text-indigo-700 mb-4 inline-block">
      ← Back to Status
    </a>
    <h1 class="text-2xl font-semibold text-slate-900 mt-2">Connected services</h1>
    <p class="mt-2 text-slate-600">
      External systems and dependencies that the platform relies on.
    </p>

    <div class="mt-8 overflow-x-auto rounded-lg border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Service</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-600">Last updated</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          {systems.map((sys) => (
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-slate-900">{sys.name}</td>
              <td class="px-4 py-3 text-sm text-slate-600">
                {getExternalSystemTypeLabel(sys.type)}
              </td>
              <td class="px-4 py-3">
                <StatusBadge level={sys.level} variant="pillCompact" />
              </td>
              <td class="px-4 py-3 text-sm text-slate-500">
                {new Date(sys.lastUpdated).toLocaleString()}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
