---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../components/status/StatusBadge.astro';
import { fetchExternalSystems } from '../../../lib/status/fetch-status';
import { getExternalSystemTypeLabel } from 'shared/status-labels';
import { withBase } from '../../../lib/site-url';

const { systems } = await fetchExternalSystems();
---

<BaseLayout
  title="Connected Services - Status"
  description="External systems and dependencies status"
>
  <div class="max-w-4xl mx-auto">
    <a href={withBase('roadmap/status')} class="link text-sm mb-4 inline-block">
      ← Back to Status
    </a>
    <h1 class="text-2xl font-semibold text-foreground mt-2">Connected services</h1>
    <p class="mt-2 text-secondary-foreground">
      External systems and dependencies that the platform relies on.
    </p>

    <div class="mt-8 overflow-x-auto rounded-lg border border-border">
      <table class="min-w-full divide-y divide-border">
        <thead class="bg-muted">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Service</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Type</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Status</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-secondary-foreground">Last updated</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border bg-card">
          {systems.map((sys) => (
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-foreground">{sys.name}</td>
              <td class="px-4 py-3 text-sm text-secondary-foreground">
                {getExternalSystemTypeLabel(sys.type)}
              </td>
              <td class="px-4 py-3">
                <StatusBadge level={sys.level} variant="pillCompact" />
              </td>
              <td class="px-4 py-3 text-sm text-muted-foreground">
                {new Date(sys.lastUpdated).toLocaleString()}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
