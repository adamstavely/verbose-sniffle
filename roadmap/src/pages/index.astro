---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Product Roadmap" description="See what's coming soon and vote on features you want">
  <section class="text-center">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">
      Product Roadmap
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
      See what we're building, vote on features you want, and request new ones.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/roadmap"
        class="rounded-md bg-indigo-600 px-6 py-3 text-base font-medium text-white hover:bg-indigo-500"
      >
        View Roadmap
      </a>
      <a
        href="/requests"
        class="rounded-md border border-slate-300 bg-white px-6 py-3 text-base font-medium text-slate-700 hover:bg-slate-50"
      >
        Feature Requests
      </a>
      <a
        href="/requests/new"
        class="rounded-md border border-slate-300 bg-white px-6 py-3 text-base font-medium text-slate-700 hover:bg-slate-50"
      >
        Submit Request
      </a>
    </div>
  </section>
  <section class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="font-semibold text-slate-900">Coming Soon</h2>
      <p class="mt-2 text-sm text-slate-600">
        Browse planned features and what the team is working on.
      </p>
      <a href="/roadmap" class="mt-4 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">
        View roadmap →
      </a>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="font-semibold text-slate-900">Vote</h2>
      <p class="mt-2 text-sm text-slate-600">
        Vote for features you want to see. Your voice helps us prioritize.
      </p>
      <a href="/requests" class="mt-4 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">
        Vote now →
      </a>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="font-semibold text-slate-900">Request</h2>
      <p class="mt-2 text-sm text-slate-600">
        Have an idea? Submit it and let others vote on it.
      </p>
      <a href="/requests/new" class="mt-4 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">
        Submit request →
      </a>
    </div>
  </section>
</BaseLayout>
