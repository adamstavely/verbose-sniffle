---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site-url';
import UserGuideIllustration from '../components/illustrations/UserGuideIllustration.astro';
import ReleasesIllustration from '../components/illustrations/ReleasesIllustration.astro';
import RoadmapIllustration from '../components/illustrations/RoadmapIllustration.astro';
import AboutIllustration from '../components/illustrations/AboutIllustration.astro';
import StatusIllustration from '../components/illustrations/StatusIllustration.astro';
import DeveloperGuideIllustration from '../components/illustrations/DeveloperGuideIllustration.astro';

const cards = [
  {
    Illustration: UserGuideIllustration,
    title: 'User Guide',
    description: 'Step-by-step guides for using the product and its features.',
    cta: 'Read guide',
    href: withBase('user-guide'),
  },
  {
    Illustration: ReleasesIllustration,
    title: 'Releases',
    description: "Version history, release notes, and what's new.",
    cta: 'View releases',
    href: withBase('releases'),
  },
  {
    Illustration: RoadmapIllustration,
    title: 'Roadmap',
    description: 'Browse planned features and community requests.',
    cta: 'View roadmap',
    href: withBase('roadmap'),
  },
  {
    Illustration: AboutIllustration,
    title: 'About',
    description: 'Learn about our product, mission, and the team behind it.',
    cta: 'Learn more',
    href: withBase('about'),
  },
  {
    Illustration: StatusIllustration,
    title: 'System Status',
    description: 'System status, incidents, and maintenance (sample data).',
    cta: 'View status',
    href: withBase('roadmap/status'),
  },
  {
    Illustration: DeveloperGuideIllustration,
    title: 'Developer Guide',
    description: 'API documentation, integration guides, and technical reference.',
    cta: 'View docs',
    href: withBase('developer-guide'),
  },
];
---

<BaseLayout home title="Help Center" description="Browse guides, releases, and everything about the product.">
  <section class="text-center">
    <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Hi, how can we help?</h1>
    <p class="mt-2 text-[15px] text-secondary-foreground">
      Browse guides, releases, and everything about the product.
    </p>
    <form
      role="search"
      method="get"
      action={withBase('search')}
      class="mx-auto mt-6 flex max-w-xl items-center gap-2 rounded-lg border border-border bg-card p-1.5 shadow-sm focus-within:ring-2 focus-within:ring-accent"
    >
      <label for="hero-search" class="sr-only">Search the Help Center</label>
      <svg class="ml-2 h-5 w-5 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <input
        id="hero-search"
        type="search"
        name="q"
        placeholder="Search the docs…"
        autocomplete="off"
        class="min-w-0 flex-1 bg-transparent px-1 py-1.5 text-sm text-foreground placeholder-muted-foreground focus:outline-none"
      />
    </form>
  </section>

  <section class="mt-11 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" aria-label="Help Center sections">
    {cards.map(({ Illustration, title, description, cta, href }) => (
      <a
        href={href}
        class="group flex flex-col items-center rounded-xl border border-border bg-card px-7 pt-9 pb-8 text-center shadow-sm transition duration-200 hover:-translate-y-1 hover:border-border-strong hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
      >
        <Illustration class="h-28 w-28" />
        <h2 class="mt-6 mb-2.5 text-xl font-bold text-foreground">{title}</h2>
        <p class="mb-4 line-clamp-2 min-h-[2.85rem] text-sm leading-relaxed text-secondary-foreground">{description}</p>
        <span class="text-sm font-semibold text-accent group-hover:text-accent-hover">
          {cta}&nbsp;&rarr;
        </span>
      </a>
    ))}
  </section>

  <section class="mt-12 flex flex-col items-center justify-center gap-4 text-center sm:flex-row">
    <p class="text-lg font-semibold text-foreground">Still need help?</p>
    <button
      type="button"
      data-open-support
      class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 dark:text-slate-900"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" />
      </svg>
      Contact support
    </button>
  </section>
</BaseLayout>
