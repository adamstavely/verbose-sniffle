---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Product Roadmap" description="See what's coming soon and vote on features you want">
  <section class="text-center">
    <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">
      Product Roadmap
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
      See what we're building and vote on features you want.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/roadmap"
        class="rounded-md bg-indigo-600 px-6 py-3 text-base font-medium text-white hover:bg-indigo-500"
      >
        View Roadmap
      </a>
      <a
        href="/roadmap/status"
        class="rounded-md border border-slate-300 bg-white px-6 py-3 text-base font-medium text-slate-700 hover:bg-slate-50"
      >
        Status
      </a>
    </div>
  </section>
  <section class="mt-16 grid gap-8 sm:grid-cols-2">
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="font-semibold text-slate-900">Roadmap</h2>
      <p class="mt-2 text-sm text-slate-600">
        Browse planned features, vote on what you want, and see community requests.
      </p>
      <a href="/roadmap" class="mt-4 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">
        View roadmap →
      </a>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="font-semibold text-slate-900">Status</h2>
      <p class="mt-2 text-sm text-slate-600">
        Real-time platform status, incidents, and maintenance.
      </p>
      <a href="/roadmap/status" class="mt-4 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">
        View status →
      </a>
    </div>
  </section>
</BaseLayout>
