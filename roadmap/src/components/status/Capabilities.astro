---
import type { CapabilityGroup, StatusLevel } from 'shared/status-models';
import StatusBadge from './StatusBadge.astro';
import { getStatusLabel } from 'shared/status-labels';

interface Props {
  groups: CapabilityGroup[];
}

const { groups } = Astro.props;

function groupWorstStatus(group: CapabilityGroup): StatusLevel {
  if (group.items.some((i) => i.level === 'OUTAGE')) return 'OUTAGE';
  if (group.items.some((i) => i.level === 'DEGRADED')) return 'DEGRADED';
  if (group.items.some((i) => i.level === 'MAINTENANCE')) return 'MAINTENANCE';
  // Don't report "all operational" when telemetry is unknown for any item.
  if (group.items.some((i) => i.level === 'UNKNOWN')) return 'UNKNOWN';
  return 'HEALTHY';
}

// Group accent bars are decorative brand markers, not status — they use the
// primary brand color so they never read as a semantic (success/warning) signal.
function barColorClass(_color: string): string {
  return 'bg-primary';
}
---

<div class="space-y-6" aria-label="Capabilities by workspace">
  {groups.map((group) => {
    const worst = groupWorstStatus(group);
    return (
      <div class="capability-group">
        <div class="flex items-center gap-2.5 mb-2">
          <span class={`w-1 h-4 rounded shrink-0 ${barColorClass(group.barColor)}`} />
          <span class="text-[10px] font-semibold uppercase tracking-widest text-accent">
            {group.group}
          </span>
          <span class="flex-1" />
          <span class="text-[10px] flex items-center gap-1">
            <StatusBadge level={worst} variant="dot" />
            {getStatusLabel(worst)}
          </span>
        </div>
        <div class="rounded-lg overflow-hidden border border-border bg-card">
          {group.items.map((item) => {
            const hasImpact = Boolean(item.impact);
            const trailing = (
              <div class="flex w-[9.25rem] shrink-0 items-center gap-3">
                <span class="inline-flex w-[6.5rem] shrink-0">
                  <StatusBadge level={item.level} variant="pill" />
                </span>
                <span class="flex h-4 w-4 shrink-0 items-center justify-center text-muted-foreground">
                  {hasImpact && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 transition-transform group-open:rotate-90">
                      <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.21 6.29a.75.75 0 111.02-1.1l4.5 4.25a.75.75 0 010 1.06l-4.5 4.25a.75.75 0 01-1.02-.02z" clip-rule="evenodd" />
                    </svg>
                  )}
                </span>
              </div>
            );

            return hasImpact ? (
              <details class="group border-b border-border last:border-b-0">
                <summary class="flex items-center gap-3 px-4 py-3 text-left cursor-pointer list-none hover:bg-muted transition-colors [&::-webkit-details-marker]:hidden">
                  <StatusBadge level={item.level} variant="dot" />
                  <span class="flex-1 text-[13px] text-foreground">{item.label}</span>
                  {trailing}
                </summary>
                <div class="px-4 py-3 pl-14 border-t border-border bg-muted/30">
                  <p class="text-[12px] text-secondary-foreground leading-relaxed border-l-2 border-warning pl-3">
                    {item.impact}
                  </p>
                </div>
              </details>
            ) : (
              <div class="flex items-center gap-3 px-4 py-3 border-b border-border last:border-b-0">
                <StatusBadge level={item.level} variant="dot" />
                <span class="flex-1 text-[13px] text-foreground">{item.label}</span>
                {trailing}
              </div>
            );
          })}
        </div>
      </div>
    );
  })}
</div>
