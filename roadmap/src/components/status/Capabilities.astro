---
import type { CapabilityGroup } from 'shared/status-models';
import StatusBadge from './StatusBadge.astro';
import { getStatusLabel } from 'shared/status-labels';

interface Props {
  groups: CapabilityGroup[];
}

const { groups } = Astro.props;

function groupWorstStatus(group: CapabilityGroup): 'HEALTHY' | 'DEGRADED' | 'OUTAGE' | 'MAINTENANCE' {
  if (group.items.some((i) => i.level === 'OUTAGE')) return 'OUTAGE';
  if (group.items.some((i) => i.level === 'DEGRADED')) return 'DEGRADED';
  if (group.items.some((i) => i.level === 'MAINTENANCE')) return 'MAINTENANCE';
  return 'HEALTHY';
}

function barColorClass(color: string): string {
  switch (color) {
    case 'violet-500': return 'bg-violet-500';
    case 'amber-500': return 'bg-amber-500';
    case 'sky-500': return 'bg-sky-500';
    default: return 'bg-slate-500';
  }
}

function barTextClass(color: string): string {
  switch (color) {
    case 'violet-500': return 'text-violet-500';
    case 'amber-500': return 'text-amber-500';
    case 'sky-500': return 'text-sky-500';
    default: return 'text-slate-500';
  }
}
---

<div class="space-y-6" aria-label="Capabilities by workspace">
  {groups.map((group) => {
    const worst = groupWorstStatus(group);
    return (
      <div class="capability-group">
        <div class="flex items-center gap-2.5 mb-2">
          <span class={`w-1 h-4 rounded shrink-0 ${barColorClass(group.barColor)}`} />
          <span class={`text-[10px] font-mono font-semibold uppercase tracking-widest ${barTextClass(group.barColor)}`}>
            {group.group}
          </span>
          <span class="flex-1" />
          <span class="text-[10px] font-mono flex items-center gap-1">
            <StatusBadge level={worst} variant="dot" />
            {getStatusLabel(worst)}
          </span>
        </div>
        <div class="rounded-lg overflow-hidden border border-slate-200 bg-white">
          {group.items.map((item) => (
            item.impact ? (
              <details class="group border-b border-slate-100 last:border-b-0">
                <summary class="flex items-center gap-3 px-4 py-3 text-left cursor-pointer list-none hover:bg-slate-50 transition-colors [&::-webkit-details-marker]:hidden">
                  <StatusBadge level={item.level} variant="dot" />
                  <span class="flex-1 text-[13px] text-slate-900">{item.label}</span>
                  {item.aiNote && item.level !== 'HEALTHY' && (
                    <span class="text-[9px] font-mono font-semibold text-violet-500 bg-violet-500/10 border border-violet-500/30 rounded px-1.5 py-0.5 shrink-0">
                      AI NOTE
                    </span>
                  )}
                  <StatusBadge level={item.level} variant="pill" />
                  <span class="text-slate-400 text-[10px] shrink-0 transition-transform group-open:rotate-90">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                      <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.21 6.29a.75.75 0 111.02-1.1l4.5 4.25a.75.75 0 010 1.06l-4.5 4.25a.75.75 0 01-1.02-.02z" clip-rule="evenodd" />
                    </svg>
                  </span>
                </summary>
                <div class="px-4 py-3 pl-14 border-t border-slate-100 bg-slate-50/30">
                  <p class="text-[12px] text-slate-600 leading-relaxed border-l-2 border-amber-500/50 pl-3">
                    {item.impact}
                  </p>
                </div>
              </details>
            ) : (
              <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-100 last:border-b-0">
                <StatusBadge level={item.level} variant="dot" />
                <span class="flex-1 text-[13px] text-slate-900">{item.label}</span>
                {item.aiNote && item.level !== 'HEALTHY' && (
                  <span class="text-[9px] font-mono font-semibold text-violet-500 bg-violet-500/10 border border-violet-500/30 rounded px-1.5 py-0.5 shrink-0">
                    AI NOTE
                  </span>
                )}
                <StatusBadge level={item.level} variant="pill" />
              </div>
            )
          ))}
        </div>
      </div>
    );
  })}
</div>
