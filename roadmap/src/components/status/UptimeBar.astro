---
import type { UptimeData } from 'shared/status-models';

interface Props {
  data: UptimeData;
}

// `data` is required and always real (or mock in demo mode) — never fabricate
// uptime here. The status page renders "unavailable" when the series is empty.
const { data: uptime } = Astro.props;

function getBarClasses(day: UptimeData['days'][number]): string {
  const base = 'flex-1 rounded-sm min-w-[2px] transition-[height] duration-100';
  const height =
    day === 'unavailable' ? 'h-7' : day === 'degraded' ? 'h-5' : 'h-3.5';
  const color =
    day === 'unavailable'
      ? 'bg-danger'
      : day === 'degraded'
        ? 'bg-warning'
        : 'bg-success/80';
  return `${base} ${height} ${color}`;
}
---

<div
  class="rounded-lg border border-border bg-card p-5 md:p-6"
  aria-labelledby="uptime-heading"
>
  <div class="flex items-center mb-3">
    <span class="flex-1"></span>
    <span class="font-mono text-sm font-semibold text-success">
      {uptime.percentage}%
    </span>
  </div>
  <div
    class="flex gap-0.5 items-end h-7"
    role="img"
    aria-label={`${uptime.percentage}% uptime over the last 90 days`}
  >
    {uptime.days.map((day, i) => (
      <div
        class={getBarClasses(day)}
        title={`${day} - day ${i + 1}`}
      />
    ))}
  </div>
  <div class="flex justify-between mt-1.5">
    <span class="text-[10px] text-muted-foreground">90 days ago</span>
    <span class="text-[10px] text-muted-foreground">Today</span>
  </div>
</div>
