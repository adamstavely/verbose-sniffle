---
import type { UptimeData } from 'shared/status-models';
import { getMockUptime } from '../../lib/status/mock-data';

interface Props {
  data?: UptimeData | null;
}

const { data } = Astro.props;
const uptime = data ?? getMockUptime();

function getBarClasses(day: UptimeData['days'][number]): string {
  const base = 'flex-1 rounded-sm min-w-[2px] transition-[height] duration-100';
  const height =
    day === 'unavailable' ? 'h-7' : day === 'degraded' ? 'h-5' : 'h-3.5';
  const color =
    day === 'unavailable'
      ? 'bg-red-500'
      : day === 'degraded'
        ? 'bg-amber-500'
        : 'bg-emerald-500/80';
  return `${base} ${height} ${color}`;
}
---

<div
  class="rounded-lg border border-slate-200 bg-white p-5 md:p-6"
  aria-labelledby="uptime-heading"
>
  <div class="flex items-center mb-3">
    <span class="flex-1"></span>
    <span class="font-mono text-sm font-semibold text-emerald-600">
      {uptime.percentage}%
    </span>
  </div>
  <div
    class="flex gap-0.5 items-end h-7"
    role="img"
    aria-label={`${uptime.percentage}% uptime over the last 90 days`}
  >
    {uptime.days.map((day, i) => (
      <div
        class={getBarClasses(day)}
        title={`${day} - day ${i + 1}`}
      />
    ))}
  </div>
  <div class="flex justify-between mt-1.5">
    <span class="font-mono text-[10px] text-slate-400">90 days ago</span>
    <span class="font-mono text-[10px] text-slate-400">Today</span>
  </div>
</div>
