---
import type { StatusLevel, UptimeData } from 'shared/status-models';

export interface StatusRow {
  name: string;
  level: StatusLevel;
  uptime?: UptimeData;
  /** Muted label shown after the name (e.g. a system type). */
  meta?: string;
  /** Tooltip shown on an (i) icon after the name (e.g. an impact note). */
  info?: string;
}

interface Props {
  title: string;
  rows: StatusRow[];
  rangeLabel?: string;
  link?: { href: string; label: string };
}

const { title, rows, rangeLabel, link } = Astro.props;

function statusIcon(level: StatusLevel): { kind: 'check' | 'alert'; color: string } {
  switch (level) {
    case 'HEALTHY':
      return { kind: 'check', color: 'text-success' };
    case 'OUTAGE':
      return { kind: 'alert', color: 'text-danger' };
    case 'DEGRADED':
    case 'MAINTENANCE':
      return { kind: 'alert', color: 'text-warning' };
    default:
      return { kind: 'alert', color: 'text-muted-foreground' };
  }
}

function barColor(day: UptimeData['days'][number]): string {
  return day === 'unavailable'
    ? 'bg-danger'
    : day === 'degraded'
      ? 'bg-warning'
      : 'bg-success/70';
}
---

<div class="overflow-hidden rounded-xl border border-border bg-card">
  <div class="flex items-center justify-between gap-4 border-b border-border px-5 py-4">
    <h2 class="text-lg font-semibold text-foreground">{title}</h2>
    <div class="flex items-center gap-4">
      {rangeLabel && <span class="text-sm text-muted-foreground">{rangeLabel}</span>}
      {link && (
        <a href={link.href} class="text-sm font-medium text-accent-hover hover:text-accent">{link.label}</a>
      )}
    </div>
  </div>

  <ul class="divide-y divide-border">
    {rows.map((row) => {
      const icon = statusIcon(row.level);
      const uptime = row.uptime;
      return (
        <li class="px-5 py-4">
          <div class="mb-2.5 flex items-center justify-between gap-4">
            <div class="flex min-w-0 items-center gap-2.5">
              <span class={`shrink-0 ${icon.color}`}>
                {icon.kind === 'check' ? (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="m9 11 3 3L22 4" />
                  </svg>
                ) : (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" /><path d="M12 8v4" /><path d="M12 16h.01" />
                  </svg>
                )}
              </span>
              <span class="truncate font-medium text-foreground">{row.name}</span>
              {row.meta && <span class="shrink-0 text-sm text-muted-foreground">{row.meta}</span>}
              {row.info && (
                <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <title>{row.info}</title>
                  <circle cx="12" cy="12" r="10" /><path d="M12 16v-4" /><path d="M12 8h.01" />
                </svg>
              )}
            </div>
            {uptime && uptime.days.length > 0 && (
              <span class="shrink-0 font-mono text-sm text-muted-foreground">{uptime.percentage}% uptime</span>
            )}
          </div>

          {uptime && uptime.days.length > 0 ? (
            <div class="flex h-8 items-stretch gap-px" role="img" aria-label={`${uptime.percentage}% uptime over the last 90 days`}>
              {uptime.days.map((day) => (
                <span class={`min-w-[2px] flex-1 rounded-[1px] ${barColor(day)}`} />
              ))}
            </div>
          ) : (
            <p class="text-sm text-muted-foreground">Uptime data is currently unavailable.</p>
          )}
        </li>
      );
    })}
  </ul>
</div>
