---
import type { StatusLevel } from 'shared/status-models';
import { getStatusDotClass, getStatusTextClass } from 'shared/status-utils';

interface Props {
  level: StatusLevel | null | undefined;
  variant?: 'pill' | 'pillCompact' | 'dot' | 'text';
}

const { level, variant = 'pillCompact' } = Astro.props;

const SHORT_LABELS: Record<StatusLevel, string> = {
  HEALTHY: 'Operational',
  DEGRADED: 'Degraded',
  OUTAGE: 'Outage',
  MAINTENANCE: 'Maintenance',
  UNKNOWN: 'Unknown',
};

const label = level ? (SHORT_LABELS[level] ?? level) : 'Unknown';
---

{variant === 'dot' ? (
  <span class={`inline-block w-2 h-2 rounded-full shrink-0 ${getStatusDotClass(level)}`} aria-hidden />
) : variant === 'text' ? (
  <span class={getStatusTextClass(level)}>{label}</span>
) : (
  <span
    class="inline-flex items-center gap-1.5 rounded-md border border-border bg-muted px-2 py-0.5 text-xs font-medium text-secondary-foreground"
    aria-label={label}
  >
    <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${getStatusDotClass(level)}`} />
    {label}
  </span>
)}
