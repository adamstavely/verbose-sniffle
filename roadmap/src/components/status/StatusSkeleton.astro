---
/** Skeleton UI shown while status data loads. Matches the layout of the real status page. */
---
<div class="max-w-4xl mx-auto space-y-12 animate-pulse" aria-busy="true" aria-label="Loading status">
  <!-- Header -->
  <section class="rounded-xl border border-slate-200 p-6 bg-slate-100/50">
    <div class="h-7 w-48 bg-slate-200 rounded"></div>
    <div class="mt-3 h-4 w-full max-w-md bg-slate-200 rounded"></div>
    <div class="mt-2 h-3 w-32 bg-slate-200 rounded"></div>
  </section>

  <!-- Capabilities -->
  <section>
    <div class="h-5 w-28 bg-slate-200 rounded mb-3"></div>
    <div class="h-4 w-full max-w-xl bg-slate-200 rounded mb-4"></div>
    <div class="space-y-6">
      <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-100">
          <div class="w-1 h-4 bg-slate-200 rounded"></div>
          <div class="h-3 w-36 bg-slate-200 rounded"></div>
        </div>
        {[1, 2, 3, 4, 5].map(() => (
          <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-100 last:border-b-0">
            <div class="w-2 h-2 bg-slate-200 rounded-full"></div>
            <div class="h-3 flex-1 max-w-[200px] bg-slate-200 rounded"></div>
            <div class="h-5 w-20 bg-slate-200 rounded"></div>
          </div>
        ))}
      </div>
      <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-100">
          <div class="w-1 h-4 bg-slate-200 rounded"></div>
          <div class="h-3 w-40 bg-slate-200 rounded"></div>
        </div>
        {[1, 2, 3, 4].map(() => (
          <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-100 last:border-b-0">
            <div class="w-2 h-2 bg-slate-200 rounded-full"></div>
            <div class="h-3 flex-1 max-w-[180px] bg-slate-200 rounded"></div>
            <div class="h-5 w-20 bg-slate-200 rounded"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core services table -->
  <section>
    <div class="h-5 w-32 bg-slate-200 rounded mb-3"></div>
    <div class="h-4 w-64 bg-slate-200 rounded mb-4"></div>
    <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
      <div class="bg-slate-50 px-4 py-3 flex gap-4">
        <div class="h-3 w-16 bg-slate-200 rounded"></div>
        <div class="h-3 w-14 bg-slate-200 rounded"></div>
        <div class="h-3 w-24 bg-slate-200 rounded"></div>
      </div>
      {[1, 2, 3, 4, 5].map(() => (
        <div class="flex gap-4 px-4 py-3 border-t border-slate-100">
          <div class="h-4 w-28 bg-slate-200 rounded"></div>
          <div class="h-5 w-20 bg-slate-200 rounded"></div>
          <div class="h-4 w-36 bg-slate-200 rounded"></div>
        </div>
      ))}
    </div>
  </section>

  <!-- Workspaces grid -->
  <section>
    <div class="h-5 w-24 bg-slate-200 rounded mb-3"></div>
    <div class="h-4 w-48 bg-slate-200 rounded mb-4"></div>
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[1, 2, 3, 4, 5, 6].map(() => (
        <li class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="flex justify-between">
            <div class="h-4 w-24 bg-slate-200 rounded"></div>
            <div class="h-5 w-16 bg-slate-200 rounded"></div>
          </div>
          <div class="mt-2 h-3 w-16 bg-slate-200 rounded"></div>
        </li>
      ))}
    </ul>
  </section>

  <!-- Uptime bar -->
  <section>
    <div class="h-5 w-28 bg-slate-200 rounded mb-3"></div>
    <div class="h-4 w-full max-w-2xl bg-slate-200 rounded mb-4"></div>
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <div class="flex justify-end mb-3">
        <div class="h-4 w-12 bg-slate-200 rounded"></div>
      </div>
      <div class="flex gap-0.5 items-end h-7">
        {Array.from({ length: 90 }).map(() => (
          <div class="flex-1 min-w-[2px] h-4 bg-slate-200 rounded-sm"></div>
        ))}
      </div>
      <div class="flex justify-between mt-2">
        <div class="h-3 w-16 bg-slate-200 rounded"></div>
        <div class="h-3 w-12 bg-slate-200 rounded"></div>
      </div>
    </div>
  </section>

  <!-- Recent incidents -->
  <section>
    <div class="h-5 w-36 bg-slate-200 rounded mb-3"></div>
    <div class="h-4 w-72 bg-slate-200 rounded mb-4"></div>
    <ul class="space-y-2">
      {[1, 2, 3, 4, 5].map(() => (
        <li class="flex items-center justify-between rounded border border-slate-200 bg-white px-4 py-2">
          <div class="flex gap-2">
            <div class="h-4 w-20 bg-slate-200 rounded"></div>
            <div class="h-4 w-40 bg-slate-200 rounded"></div>
          </div>
          <div class="h-4 w-16 bg-slate-200 rounded"></div>
        </li>
      ))}
    </ul>
  </section>
</div>
