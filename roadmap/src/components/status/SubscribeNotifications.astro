---
// Form is handled by client script below
---

<section
  class="subscribe-section rounded-xl overflow-hidden border border-slate-200 bg-slate-50 p-5 md:p-6"
  aria-labelledby="subscribe-heading"
>
  <h2 id="subscribe-heading" class="font-semibold text-slate-900 text-[15px]">
    Get incident notifications
  </h2>
  <p class="text-[13px] text-slate-500 mt-1">
    Email or Microsoft Teams webhook
  </p>
  <form id="subscribe-form" class="mt-4 flex flex-col sm:flex-row gap-3">
    <input
      type="text"
      name="subscribeEmail"
      placeholder="your@email.gov"
      class="flex-1 min-w-0 px-4 py-2.5 rounded-lg border border-slate-200 bg-white text-slate-900 placeholder-slate-400 text-[14px] focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent"
    />
    <button
      type="submit"
      class="px-5 py-2.5 rounded-lg border-2 border-amber-500 text-amber-600 bg-transparent font-semibold text-[12px] uppercase tracking-wider hover:bg-amber-500/10 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2"
    >
      Subscribe
    </button>
  </form>
  <p id="subscribe-thanks" class="mt-3 text-[13px] text-amber-600 hidden">
    Thanks! We'll send notifications to that address.
  </p>
</section>

<script>
  document.getElementById('subscribe-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const thanks = document.getElementById('subscribe-thanks');
    if (thanks) {
      thanks.classList.remove('hidden');
    }
    // TODO: wire to backend subscribe API
  });
</script>
