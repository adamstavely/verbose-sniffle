---
import { actions } from 'astro:actions';

interface Props {
  result?: { success: boolean; error?: string } | null;
}

const { result } = Astro.props;
---

<div class="rounded-lg border border-border bg-card p-5 md:p-6" aria-labelledby="subscribe-heading">
  <form method="POST" action={actions.subscribe} class="flex flex-col sm:flex-row gap-3">
    <label for="subscribe-email" class="sr-only">Email address for incident notifications</label>
    <input
      id="subscribe-email"
      type="email"
      name="email"
      placeholder="your@email.gov"
      required
      class="flex-1 min-w-0 px-4 py-2.5 rounded-lg border border-border bg-card text-foreground placeholder-muted-foreground text-[14px] focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
    />
    <button
      type="submit"
      class="px-5 py-2.5 rounded-lg border-2 border-accent text-accent bg-transparent font-semibold text-[12px] uppercase tracking-wider hover:bg-accent-subtle transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
    >
      Subscribe
    </button>
  </form>
  {result?.success && (
    <p class="mt-3 text-[13px] text-success">
      Thanks! We'll send notifications to that address.
    </p>
  )}
  {result && !result.success && result.error && (
    <p class="mt-3 text-[13px] text-danger">
      {result.error}
    </p>
  )}
</div>
