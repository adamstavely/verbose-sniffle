---
// Colour key for the uptime bars, shared by the Service health and Connected
// services cards.
const items = [
  { label: 'Operational', class: 'bg-success/70' },
  { label: 'Degraded', class: 'bg-warning' },
  { label: 'Outage', class: 'bg-danger' },
];
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 px-1 text-xs text-muted-foreground">
  <span class="font-medium text-secondary-foreground">Key</span>
  {items.map((item) => (
    <span class="flex items-center gap-1.5">
      <span class={`h-2.5 w-2.5 rounded-sm ${item.class}`} aria-hidden="true" />
      {item.label}
    </span>
  ))}
</div>
