---
import type {
  IncidentSummary,
  ScheduledMaintenance,
  StatusLevel,
} from 'shared/status-models';
import { withBase } from '../../lib/site-url';

interface Props {
  level: StatusLevel;
  incidents: IncidentSummary[];
  maintenance?: ScheduledMaintenance[];
}

const { level, incidents, maintenance = [] } = Astro.props;

// The hero is a SINGLE state, chosen by priority — never a mix. Outage outranks
// degraded, which outranks maintenance, which outranks all-clear. "Unknown" is a
// separate honest state for when telemetry can't be reached.
type Hero = 'outage' | 'degraded' | 'maintenance' | 'operational' | 'unknown';
const levels = new Set<StatusLevel>([level, ...incidents.map((i) => i.level)]);
const hero: Hero = levels.has('OUTAGE')
  ? 'outage'
  : levels.has('DEGRADED')
    ? 'degraded'
    : maintenance.length > 0 || levels.has('MAINTENANCE')
      ? 'maintenance'
      : level === 'UNKNOWN' && incidents.length === 0
        ? 'unknown'
        : 'operational';

const HERO = {
  outage: { border: 'border-danger', bg: 'bg-danger-subtle', icon: 'text-danger', title: "We're currently experiencing issues" },
  degraded: { border: 'border-warning/50', bg: 'bg-warning-subtle', icon: 'text-warning', title: 'Some systems are degraded' },
  maintenance: { border: 'border-info/40', bg: 'bg-info-subtle', icon: 'text-info', title: 'Scheduled maintenance' },
  operational: { border: 'border-success', bg: 'bg-success-subtle', icon: 'text-success', title: "We're fully operational" },
  unknown: { border: 'border-border', bg: 'bg-muted', icon: 'text-muted-foreground', title: "We're checking system status" },
} as const;
const h = HERO[hero];

const isIncidentHero = hero === 'outage' || hero === 'degraded';
const isMaintenanceHero = hero === 'maintenance';

function ongoingFor(startedAt: string): string {
  const ms = Date.now() - new Date(startedAt).getTime();
  const mins = Math.max(1, Math.floor(ms / 60000));
  if (mins < 60) return `${mins} min`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours} hour${hours === 1 ? '' : 's'}`;
  const days = Math.floor(hours / 24);
  return `${days} day${days === 1 ? '' : 's'}`;
}

function latestStatus(inc: IncidentSummary): string {
  return inc.updates?.[inc.updates.length - 1]?.status ?? 'Investigating';
}

function formatList(items: string[]): string {
  if (items.length <= 1) return items.join('');
  if (items.length === 2) return `${items[0]} and ${items[1]}`;
  return `${items.slice(0, -1).join(', ')}, and ${items[items.length - 1]}`;
}

function incidentMeta(inc: IncidentSummary): string {
  const parts = [latestStatus(inc), `Ongoing for ${ongoingFor(inc.startedAt)}`];
  if (inc.affects?.length) parts.push(`Affects ${formatList(inc.affects)}`);
  return parts.join(' · ');
}

const MAINTENANCE_STATUS: Record<string, string> = {
  SCHEDULED: 'Scheduled',
  IN_PROGRESS: 'In progress',
  COMPLETED: 'Completed',
};
function maintenanceMeta(m: ScheduledMaintenance): string {
  const when = `${new Date(m.scheduledStart).toLocaleString()} – ${new Date(m.scheduledEnd).toLocaleString()}`;
  return `${MAINTENANCE_STATUS[m.status] ?? m.status} · ${when}`;
}

const affectedAreas = [...new Set(incidents.flatMap((inc) => inc.affects ?? []))];
const alertIcon =
  'M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z';
---

<section aria-labelledby="status-banner-title" class={`overflow-hidden rounded-xl border ${h.border}`}>
  <div class={`flex items-center gap-2.5 px-5 py-4 ${h.bg}`}>
    {hero === 'operational' ? (
      <svg class={`h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="m9 11 3 3L22 4" />
      </svg>
    ) : hero === 'maintenance' ? (
      <svg class={`h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
      </svg>
    ) : hero === 'unknown' ? (
      <svg class={`h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" />
      </svg>
    ) : (
      <svg class={`h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={alertIcon} /><path d="M12 9v4" /><path d="M12 17h.01" />
      </svg>
    )}
    <h1 id="status-banner-title" class="text-lg font-semibold text-foreground">{h.title}</h1>
  </div>

  <div class="bg-card px-5 py-4">
    {hero === 'operational' ? (
      <p class="text-secondary-foreground">We're not aware of any issues affecting our systems.</p>
    ) : hero === 'unknown' ? (
      <p class="text-secondary-foreground">We're unable to determine system status right now. See <strong class="font-medium text-foreground">System status</strong> below.</p>
    ) : isMaintenanceHero ? (
      <ul class="divide-y divide-border">
        {maintenance.map((m) => (
          <li class="py-4 first:pt-0 last:pb-0">
            <div class="flex items-start gap-3">
              <svg class={`mt-0.5 h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
              </svg>
              <div class="min-w-0">
                <span class="font-semibold text-foreground">{m.title}</span>
                {m.description && <p class="mt-1 text-sm text-secondary-foreground">{m.description}</p>}
                <p class="mt-2 text-sm text-muted-foreground">{maintenanceMeta(m)}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    ) : incidents.length > 0 ? (
      <>
        {affectedAreas.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {affectedAreas.map((area) => (
              <span class="rounded-md bg-warning-subtle px-2.5 py-1 text-sm font-medium text-warning-strong">{area}</span>
            ))}
          </div>
        )}
        <ul class="divide-y divide-border">
          {incidents.map((inc) => (
            <li class="py-4 first:pt-0 last:pb-0">
              <div class="flex items-start gap-3">
                <svg class={`mt-0.5 h-5 w-5 shrink-0 ${h.icon}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={alertIcon} /><path d="M12 9v4" /><path d="M12 17h.01" />
                </svg>
                <div class="min-w-0">
                  <a href={withBase(`roadmap/status/incidents/${inc.id}`)} class="font-semibold text-foreground hover:text-accent">{inc.title}</a>
                  {inc.description && <p class="mt-1 text-sm text-secondary-foreground">{inc.description}</p>}
                  <p class="mt-2 text-sm text-muted-foreground">{incidentMeta(inc)}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="text-secondary-foreground">
        {hero === 'outage' ? 'One or more services are down' : 'Some services are degraded'}. See <strong class="font-medium text-foreground">System status</strong> below for details.
      </p>
    )}
  </div>
</section>
