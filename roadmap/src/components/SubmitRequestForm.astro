---
import { actions } from 'astro:actions';

const result = Astro.getActionResult(actions.submitFeatureRequest);
const hasError = result?.error;
const hasSuccess = result && !result.error;
---

{hasSuccess && (
  <p class="mb-4 rounded-md bg-green-50 p-4 text-sm text-green-800" role="status">
    Your feature request has been submitted. Thank you!
  </p>
)}
{hasError && (
  <p class="mb-4 rounded-md bg-red-50 p-4 text-sm text-red-800" role="alert">
    {result.error?.message ?? 'Something went wrong. Please try again.'}
  </p>
)}
<form method="POST" action={actions.submitFeatureRequest} class="space-y-4">
  <div>
    <label for="title" class="block text-sm font-medium text-slate-700">
      Title
    </label>
    <input
      type="text"
      id="title"
      name="title"
      required
      maxlength={200}
      class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
      placeholder="e.g. Dark mode support"
    />
  </div>
  <div>
    <label for="description" class="block text-sm font-medium text-slate-700">
      Description
    </label>
    <textarea
      id="description"
      name="description"
      required
      maxlength={2000}
      rows={4}
      class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
      placeholder="Describe the feature and why it would be useful..."
    />
  </div>
  <button
    type="submit"
    class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500"
  >
    Submit Request
  </button>
</form>
