---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<!-- About: info icon - universal "about" symbol -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 140 90"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <defs>
    <linearGradient id="about-info-grad" x1="0%" y1="1" x2="0%" y2="0">
      <stop offset="0%" stop-color="rgb(99 102 241)" />
      <stop offset="100%" stop-color="rgb(129 140 248)" />
    </linearGradient>
  </defs>
  <!-- Large info circle -->
  <circle cx="70" cy="45" r="32" fill="url(#about-info-grad)" stroke="white" stroke-width="3" />
  <!-- "i" dot -->
  <circle cx="70" cy="32" r="4" fill="white" />
  <!-- "i" stem -->
  <rect x="66" y="42" width="8" height="18" rx="2" fill="white" />
</svg>
