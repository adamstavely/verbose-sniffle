---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<!-- About card illustration (Design System --ill-* tokens; themes in dark mode). -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 96 96"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <rect x="10" y="12" width="76" height="72" rx="22" fill="var(--ill-bg)"></rect>
  <rect x="24" y="32" width="33" height="40" rx="7" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4" transform="rotate(-11 40 52)"></rect>
  <g transform="rotate(7 54 49)">
  <rect x="37" y="27" width="34" height="44" rx="7" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4"></rect>
  <rect x="44" y="34" width="13" height="13" rx="4" fill="var(--ill-primary)"></rect>
  <line x1="44" y1="54" x2="64" y2="54" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round"></line>
  <line x1="44" y1="61" x2="58" y2="61" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round"></line>
  </g>
</svg>
