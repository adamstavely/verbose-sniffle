---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<!-- User Guide: open book with a bookmark -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 96 96"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <rect x="10" y="12" width="76" height="72" rx="22" fill="var(--ill-bg)" />
  <path d="M48 32 C41 28 33 27 24.5 29.5 L24.5 66 C33 63.5 41 64.5 48 68.5 Z" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4" stroke-linejoin="round" />
  <path d="M48 32 C55 28 63 27 71.5 29.5 L71.5 66 C63 63.5 55 64.5 48 68.5 Z" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4" stroke-linejoin="round" />
  <line x1="48" y1="34" x2="48" y2="67" stroke="var(--ill-ink)" stroke-width="2.4" />
  <line x1="31" y1="40" x2="42" y2="39" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" />
  <line x1="31" y1="47" x2="42" y2="46" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" />
  <line x1="54" y1="39" x2="65" y2="40" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" />
  <path d="M58 26 L58 44 L63 39 L68 44 L68 26 Z" fill="var(--ill-primary)" />
</svg>
