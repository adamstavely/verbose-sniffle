---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<!-- Status card illustration (Design System --ill-* tokens; themes in dark mode). -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 96 96"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <rect x="10" y="12" width="76" height="72" rx="22" fill="var(--ill-bg)"></rect>
  <g transform="translate(48 51) scale(0.9) translate(-48 -51)">
  <rect x="16" y="23" width="64" height="44" rx="7" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4"></rect>
  <circle cx="27" cy="34" r="3" fill="var(--ill-primary)"></circle>
  <line x1="34" y1="34" x2="70" y2="34" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" stroke-dasharray="1.5 5"></line>
  <circle cx="27" cy="45" r="3" fill="var(--ill-primary)"></circle>
  <line x1="34" y1="45" x2="70" y2="45" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" stroke-dasharray="1.5 5"></line>
  <circle cx="27" cy="56" r="3" fill="var(--sub)"></circle>
  <line x1="34" y1="56" x2="70" y2="56" stroke="var(--ill-paper-line)" stroke-width="2.2" stroke-linecap="round" stroke-dasharray="1.5 5"></line>
  <path d="M43 67 L42 78 h12 l-1 -11 Z" fill="var(--ill-paper)" stroke="var(--ill-ink)" stroke-width="2.4" stroke-linejoin="round"></path>
  <line x1="34" y1="80" x2="62" y2="80" stroke="var(--ill-ink)" stroke-width="3" stroke-linecap="round"></line>
  </g>
</svg>
