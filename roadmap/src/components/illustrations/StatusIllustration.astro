---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<!-- Status: monitor showing a service health checklist -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 96 96"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <rect x="10" y="12" width="76" height="72" rx="22" fill="var(--ill-bg)" />
  <rect x="16" y="23" width="64" height="44" rx="7" fill="var(--ill-paper)" stroke="var(--ill-paper-border)" stroke-width="1.6" />
  <circle cx="27" cy="34" r="3" fill="#16A34A" />
  <line x1="34" y1="34" x2="70" y2="34" stroke="var(--ill-hairline)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="1.5 5" />
  <circle cx="27" cy="45" r="3" fill="#16A34A" />
  <line x1="34" y1="45" x2="70" y2="45" stroke="var(--ill-hairline)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="1.5 5" />
  <circle cx="27" cy="56" r="3" fill="#EABA1C" />
  <line x1="34" y1="56" x2="70" y2="56" stroke="var(--ill-hairline)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="1.5 5" />
  <path d="M42 78 h12 v-11 h-12 Z" fill="var(--ill-paper-line)" />
  <rect x="34" y="76" width="28" height="4" rx="2" fill="var(--ill-paper-line)" />
</svg>
