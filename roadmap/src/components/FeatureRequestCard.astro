---
import { actions } from 'astro:actions';

interface Props {
  id: string;
  title: string;
  description: string;
  voteCount: number;
  status: string;
  hasVoted?: boolean;
}

const { id, title, description, voteCount, status, hasVoted = false } = Astro.props;
---

<article class="rounded-lg border border-border bg-card p-4 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <h3 class="font-medium text-foreground">{title}</h3>
      <p class="mt-1 text-sm text-secondary-foreground">{description}</p>
      <span class="mt-2 inline-block rounded bg-muted px-2 py-0.5 text-xs capitalize text-secondary-foreground">
        {status}
      </span>
    </div>
    <form method="POST" action={actions.vote} class="flex shrink-0 flex-col items-center gap-1">
      <input type="hidden" name="featureRequestId" value={id} />
      <button
        type="submit"
        disabled={hasVoted}
        class={`flex flex-col items-center rounded-md border px-3 py-2 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 ${
          hasVoted
            ? 'cursor-not-allowed border-accent bg-accent-subtle text-accent'
            : 'border-border text-secondary-foreground hover:bg-muted'
        }`}
        aria-label={hasVoted ? `You voted for ${title} (${voteCount} votes)` : `Vote for ${title} (${voteCount} votes)`}
      >
        <span class="text-lg" aria-hidden="true">{hasVoted ? '✓' : '↑'}</span>
        <span>{voteCount}</span>
      </button>
    </form>
  </div>
</article>
