---
import { actions } from 'astro:actions';

interface Props {
  id: string;
  title: string;
  description: string;
  voteCount: number;
  status: string;
  hasVoted?: boolean;
}

const { id, title, description, voteCount, status, hasVoted = false } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <h3 class="font-medium text-slate-900">{title}</h3>
      <p class="mt-1 text-sm text-slate-600">{description}</p>
      <span class="mt-2 inline-block rounded bg-slate-100 px-2 py-0.5 text-xs capitalize text-slate-600">
        {status}
      </span>
    </div>
    <form method="POST" action={actions.vote} class="flex shrink-0 flex-col items-center gap-1">
      <input type="hidden" name="featureRequestId" value={id} />
      <button
        type="submit"
        disabled={hasVoted}
        class="flex flex-col items-center rounded-md border px-3 py-2 text-sm font-medium transition-colors {hasVoted
          ? 'cursor-not-allowed border-indigo-200 bg-indigo-50 text-indigo-600'
          : 'border-slate-200 text-slate-700 hover:bg-slate-50'}"
        aria-label={hasVoted ? `You voted for ${title} (${voteCount} votes)` : `Vote for ${title} (${voteCount} votes)`}
      >
        <span class="text-lg" aria-hidden="true">{hasVoted ? '✓' : '↑'}</span>
        <span>{voteCount}</span>
      </button>
    </form>
  </div>
</article>
