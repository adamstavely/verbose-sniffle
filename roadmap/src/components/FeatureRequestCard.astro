---
interface Props {
  title: string;
  description: string;
  status: string;
}

const { title, description, status } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
  <div class="min-w-0">
    <h3 class="font-medium text-slate-900">{title}</h3>
    <p class="mt-1 text-sm text-slate-600">{description}</p>
    <span class="mt-2 inline-block rounded bg-slate-100 px-2 py-0.5 text-xs capitalize text-slate-600">
      {status}
    </span>
  </div>
</article>
