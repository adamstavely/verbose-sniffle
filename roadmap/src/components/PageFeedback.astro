---
import { actions } from 'astro:actions';

interface Props {
  question?: string;
  pagePath?: string;
}

const { question = 'Was this page helpful?', pagePath = Astro.url.pathname } = Astro.props;
---

<div
  id="page-feedback"
  class="mt-12 border-t border-slate-200 pt-8"
  role="group"
  aria-labelledby="page-feedback-question"
>
  <form id="page-feedback-form" method="POST" action={actions.feedback} class="hidden" aria-hidden="true">
    <input type="hidden" name="pagePath" value={pagePath} />
    <input type="hidden" name="helpful" id="page-feedback-helpful" value="" />
    <input type="hidden" name="message" id="page-feedback-msg-hidden" value="" />
  </form>
  <div id="page-feedback-buttons" class="flex w-full flex-wrap items-center justify-end gap-3">
    <p id="page-feedback-question" class="text-sm font-medium text-slate-700">
      {question}
    </p>
    <div class="flex gap-1">
      <button
        type="button"
        data-helpful="yes"
        class="rounded-lg border border-slate-200 bg-white p-2 text-slate-600 hover:bg-slate-50 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
        aria-label="Yes, this page was helpful"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z" />
          <path d="M7 10v12" />
        </svg>
      </button>
      <button
        type="button"
        data-helpful="no"
        class="rounded-lg border border-slate-200 bg-white p-2 text-slate-600 hover:bg-slate-50 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
        aria-label="No, this page was not helpful"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22a3.13 3.13 0 0 1-3-3.88Z" />
          <path d="M17 14V2" />
        </svg>
      </button>
    </div>
  </div>
  <div id="page-feedback-message-wrap" class="mt-4 hidden ml-auto w-full max-w-md">
    <label for="page-feedback-message" class="mb-2 block text-sm text-slate-600">
      What could we improve?
    </label>
    <textarea
      id="page-feedback-message"
      name="message"
      rows="3"
      maxlength="500"
      placeholder="Optional feedback..."
      class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
    ></textarea>
    <button
      type="button"
      id="page-feedback-submit"
      class="mt-2 rounded-lg border-2 border-indigo-500 px-4 py-2 text-sm font-semibold text-indigo-600 hover:bg-indigo-500/10 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
    >
      Submit feedback
    </button>
  </div>
  <p id="page-feedback-thanks" class="mt-3 w-full text-right text-sm text-indigo-600 hidden" role="status" aria-live="polite">
    Thanks for your feedback!
  </p>
  <p id="page-feedback-error" class="mt-3 w-full text-right text-sm text-red-600 hidden" role="alert">
  </p>
</div>

<script>
  (function () {
    const form = document.getElementById('page-feedback-form') as HTMLFormElement | null;
    if (!form) return;

    const actionUrl = form.action;
    const pagePathInput = form.querySelector('input[name="pagePath"]') as HTMLInputElement | null;
    const pagePath = pagePathInput?.value || '';
    const buttons = document.getElementById('page-feedback-buttons');
    const messageWrap = document.getElementById('page-feedback-message-wrap');
    const messageInput = document.getElementById('page-feedback-message');
    const submitBtn = document.getElementById('page-feedback-submit');
    const thanks = document.getElementById('page-feedback-thanks');
    const errorEl = document.getElementById('page-feedback-error');

    function hideAll() {
      buttons?.classList.add('hidden');
      messageWrap?.classList.add('hidden');
      thanks?.classList.add('hidden');
      if (errorEl) {
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
      }
    }

    function showThanks() {
      hideAll();
      thanks?.classList.remove('hidden');
    }

    function showError(msg: string) {
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }
    }

    async function submit(helpful: 'yes' | 'no', message?: string) {
      if (!actionUrl || !pagePath) return;
      hideAll();
      buttons?.classList.remove('hidden');
      showError('');

      const helpfulInput = form.querySelector('#page-feedback-helpful');
      const msgInput = form.querySelector('#page-feedback-msg-hidden');
      if (helpfulInput) helpfulInput.value = helpful;
      if (msgInput) msgInput.value = message?.trim()?.slice(0, 500) ?? '';
      const formData = new FormData(form);

      try {
        const res = await fetch(actionUrl, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json();
        const success = data?.data?.success ?? data?.success;
        const errMsg = data?.data?.error ?? data?.error ?? data?.error?.message;
        if (success) {
          showThanks();
        } else {
          showError(errMsg || 'Failed to submit. Please try again.');
        }
      } catch {
        showError('Failed to submit. Please try again.');
      }
    }

    buttons?.querySelectorAll('button[data-helpful]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const helpful = btn.getAttribute('data-helpful') as 'yes' | 'no';
        if (helpful === 'yes') {
          submit('yes');
        } else {
          buttons?.classList.add('hidden');
          messageWrap?.classList.remove('hidden');
        }
      });
    });

    submitBtn?.addEventListener('click', () => {
      const message = messageInput?.value;
      submit('no', message);
    });
  })();
</script>
