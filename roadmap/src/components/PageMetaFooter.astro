---
import PageFeedback from './PageFeedback.astro';

interface Props {
  /** ISO date string; rendered as "Last Updated: <date>". Omitted → no date. */
  lastUpdated?: string | null;
}
const { lastUpdated = null } = Astro.props;
const formatted = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';
---

<!-- items-start keeps the date pinned top-left so it never shifts when the
     feedback widget expands into its "what could we improve?" textarea. -->
<footer class="mt-12 flex flex-wrap items-start justify-between gap-4 border-t border-border pt-6">
  <p class="text-sm text-muted-foreground">
    {formatted ? `Last Updated: ${formatted}` : ''}
  </p>
  <PageFeedback bare />
</footer>
