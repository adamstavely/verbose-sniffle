---
// Shared hero for the top-level overview pages (About, User Guide, Releases,
// Roadmap, Status, Developer Guide) so their headers share one consistent style.
// - `icon` slot: optional illustration/icon rendered left of the title
// - default slot: the description text (may contain inline links)
// - `actions` slot: optional right-aligned control (e.g. RSS link, status badge)
// - `meta` slot: optional small print rendered under the description
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="mb-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-5">
      <div class="h-28 w-28 shrink-0 [&>svg]:h-full [&>svg]:w-full">
        <slot name="icon" />
      </div>
      <h1 class="text-2xl font-bold text-foreground">{title}</h1>
    </div>
    <slot name="actions" />
  </div>
  <div class="mt-2 text-secondary-foreground"><slot /></div>
  <slot name="meta" />
</header>
