---
// Shared help/support glyph (lucide "circle-help") used by the homepage
// contact button, the footer support button, and the support modal header.
interface Props {
  class?: string;
}
const { class: className = 'h-5 w-5' } = Astro.props;
---
<svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" />
</svg>
