---
export interface DocPage {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  pages: DocPage[];
  emptyText?: string;
}

const { pages, emptyText = 'No pages yet — add an .mdx file to this section.' } = Astro.props;
---

{pages.length === 0 ? (
  <p class="rounded-lg border border-dashed border-border-strong bg-muted p-6 text-secondary-foreground">
    {emptyText}
  </p>
) : (
  <ul class="space-y-3" role="list">
    {pages.map((page) => (
      <li>
        <a
          href={page.url}
          class="block rounded-lg border border-border bg-card p-4 shadow-sm transition-shadow hover:shadow-md"
        >
          <span class="font-medium text-foreground">{page.title}</span>
          {page.description && (
            <p class="mt-1 text-sm text-secondary-foreground">{page.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
)}
