---
export interface DocPage {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  pages: DocPage[];
  emptyText?: string;
  /** 'list' = full-width stacked rows (default); 'grid' = compact cards, 3–4 per row. */
  layout?: 'list' | 'grid';
}

const {
  pages,
  emptyText = 'No pages yet — add an .mdx file to this section.',
  layout = 'list',
} = Astro.props;

const listClass =
  layout === 'grid'
    ? 'grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
    : 'space-y-3';
---

{pages.length === 0 ? (
  <p class="rounded-lg border border-dashed border-border-strong bg-muted p-6 text-secondary-foreground">
    {emptyText}
  </p>
) : (
  <ul class={listClass} role="list">
    {pages.map((page) => (
      <li>
        <a
          href={page.url}
          class="flex h-full flex-col rounded-lg border border-border bg-card p-4 shadow-sm transition-shadow hover:shadow-md"
        >
          <span class="font-medium text-foreground">{page.title}</span>
          {page.description && (
            <p class={`mt-1 text-sm text-secondary-foreground${layout === 'grid' ? ' line-clamp-2' : ''}`}>
              {page.description}
            </p>
          )}
        </a>
      </li>
    ))}
  </ul>
)}
