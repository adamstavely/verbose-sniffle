# Local development: use file-based SQLite database
ASTRO_DATABASE_FILE=file:.astro/content.db

# Production: connect to remote libSQL (e.g. Turso)
# ASTRO_DB_REMOTE_URL=libsql://your-db.turso.io
# ASTRO_DB_APP_TOKEN=your-token

# Status page: fetch timeout in ms (default 15000). Set to 0 to disable.
# STATUS_FETCH_TIMEOUT_MS=15000
