# Elasticsearch (remote cluster - no local ES required)
ELASTICSEARCH_URL=https://your-cluster.example.com:9200
ELASTICSEARCH_API_KEY=your_api_key

STATUS_ENVIRONMENT=production
STATUS_TIME_WINDOW_MINUTES=5

# Elasticsearch indices. Service health + the 90-day uptime bar read live
# telemetry from these; the app never creates them (see HANDOFF.md §8).
ELASTICSEARCH_INDEX_CORE_SERVICES=status-core-services
ELASTICSEARCH_INDEX_WORKSPACES=status-workspaces
ELASTICSEARCH_INDEX_INCIDENTS=status-incidents
ELASTICSEARCH_INDEX_SCHEDULED_MAINTENANCE=status-scheduled-maintenance
ELASTICSEARCH_INDEX_ROADMAP_VOTES=roadmap-votes
ELASTICSEARCH_INDEX_PAGE_FEEDBACK=page-feedback

# Canonical site origin (canonical URLs, RSS, sitemap).
SITE_URL=https://your-status-page.example.gov

# Status page: use mock data (no Elasticsearch required)
# PUBLIC_USE_MOCK_STATUS=true

# Status page: fetch timeout in ms (default 15000). Set to 0 to disable.
# STATUS_FETCH_TIMEOUT_MS=15000

# Support ("Still need help?") modal targets. PUBLIC_* vars are exposed to the
# browser. Leave a value blank/absent to fall back to the placeholder defaults.
PUBLIC_SUPPORT_EMAIL=support@example.com
PUBLIC_SERVICENOW_URL=https://example.service-now.com/help
# NOTE: PUBLIC_SUPPORT_CHAT_ENABLED is not currently read by any code — the Live
# chat button always renders and probes window.HelpCenterChat at runtime. Wire it
# into SupportModal.astro or remove it. See HANDOFF.md §6.2.
PUBLIC_SUPPORT_CHAT_ENABLED=false
